---
// Página raíz: redirige al idioma detectado del navegador.
const base = import.meta.env.BASE_URL;
---

<html>
<head>
  <meta charset="UTF-8" />
  <title>Legis CPM - Redirigiendo...</title>
  <script define:vars={{ base }}>
    const lang = navigator.language?.startsWith('ca') || navigator.language?.startsWith('va')
      ? 'va'
      : 'es';
    const saved = localStorage.getItem('legis-cpm-lang');
    const target = saved || lang;
    const b = base.endsWith('/') ? base : base + '/';
    window.location.replace(`${b}${target}/`);
  </script>
  <noscript>
    <meta http-equiv="refresh" content={`0;url=${base.endsWith('/') ? base : base + '/'}es/`} />
  </noscript>
</head>
<body>
  <p>Redirigiendo... / Redirigint...</p>
</body>
</html>
