---
import type { GetStaticPaths } from 'astro';
import type { StructureNode } from '../../../lib/types';
import LawReaderLayout from '../../../layouts/LawReaderLayout.astro';
import ArticleContent from '../../../components/ArticleContent.astro';
import { getAllLaws, getLawBySlug } from '../../../lib/laws';
import { insertDispositionGroups, isDispositionGroup } from '../../../lib/disposition-groups';
import PromulgationClause from '../../../components/PromulgationClause.astro';

const lang = 'va' as const;

export const getStaticPaths: GetStaticPaths = () => {
  const laws = getAllLaws('va');
  return laws.map((law) => ({ params: { slug: law.slug } }));
};

const { slug } = Astro.params;
const law = getLawBySlug(slug!, lang);

if (!law) return Astro.redirect(`${import.meta.env.BASE_URL}va/`);

function renderNodes(nodes: StructureNode[]): StructureNode[] {
  const flat: StructureNode[] = [];
  for (const node of nodes) {
    flat.push(node);
    if (node.children) flat.push(...renderNodes(node.children));
  }
  return flat;
}

const allNodes = insertDispositionGroups(renderNodes(law.structure), lang);
---

<LawReaderLayout law={law} lang={lang}>
  {allNodes.map((item) => {
    if (isDispositionGroup(item)) {
      return (
        <div id={item.id} class="section-heading section-disposiciones" style="scroll-margin-top: calc(var(--header-height) + 1rem);">
          <h2>{item.title}</h2>
        </div>
      );
    }

    const node = item as StructureNode;
    const isContainer = node.type === 'titulo' || node.type === 'capitulo' || (node.children && !node.content);
    const isSectionWithContent = node.type === 'seccion' && node.content;

    if (isSectionWithContent) {
      const Tag = 'h3';
      return (
        <>
          <div id={node.id} class={`section-heading section-${node.type}`} style="scroll-margin-top: calc(var(--header-height) + 1rem);">
            <Tag>{node.title}</Tag>
          </div>
          <ArticleContent node={node} lang={lang} />
        </>
      );
    }
    if (isContainer || node.type === 'seccion') {
      const Tag = node.type === 'titulo' ? 'h2' : 'h3';
      return (
        <div id={node.id} class={`section-heading section-${node.type}`} style="scroll-margin-top: calc(var(--header-height) + 1rem);">
          <Tag>{node.title}</Tag>
        </div>
      );
    }
    if (node.content || node.versions) {
      return <ArticleContent node={node} lang={lang} />;
    }
    return null;
  })}
  {law.promulgation && (
    <PromulgationClause promulgation={law.promulgation} lang={lang} />
  )}
</LawReaderLayout>

<style>
  .section-heading {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
  }

  .section-titulo h2 {
    font-size: 1.3rem;
    color: var(--color-primary-dark);
    border-bottom: 2px solid var(--color-border);
    padding-bottom: var(--space-xs);
  }

  .section-disposiciones h2 {
    font-size: 1.15rem;
    color: var(--color-primary-dark);
    border-bottom: 2px solid var(--color-border);
    padding-bottom: var(--space-xs);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .section-capitulo h3 {
    font-size: 1.1rem;
    color: var(--color-primary);
  }

  .section-seccion h3 {
    font-size: 1rem;
    color: var(--color-text-secondary);
    font-style: italic;
  }
</style>
