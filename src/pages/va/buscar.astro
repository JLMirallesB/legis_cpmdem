---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';

const lang = 'va' as const;
const base = import.meta.env.BASE_URL;

const typeLabels: Record<string, string> = {
  decreto: t('filter.type.decreto', lang),
  orden: t('filter.type.orden', lang),
  resolucion: t('filter.type.resolucion', lang),
  ley: t('filter.type.ley', lang),
  ley_organica: t('filter.type.ley_organica', lang),
  real_decreto: t('filter.type.real_decreto', lang),
  circular: t('filter.type.circular', lang),
  documento: t('filter.type.documento', lang),
  correccion_errores: t('filter.type.correccion_errores', lang),
};
const tagLabels: Record<string, string> = {
  'scope.general': t('tag.scope.general', lang),
  'scope.musica_y_danza': t('tag.scope.musica_y_danza', lang),
  'scope.musica': t('tag.scope.musica', lang),
  'scope.danza': t('tag.scope.danza', lang),
  'territory.estatal': t('tag.territory.estatal', lang),
  'territory.autonomico': t('tag.territory.autonomico', lang),
  'temporality.permanente': t('tag.temporality.permanente', lang),
  'temporality.anual': 'Anual',
  'docType.normativa': t('tag.docType.normativa', lang),
  'docType.documentos': t('tag.docType.documentos', lang),
};
---

<BaseLayout lang={lang} title={t('search.results', lang)}>
  <div class="container search-page">
    <h1>{t('search.results', lang)}</h1>

    <div class="search-box">
      <form action={`${base}va/buscar/`} method="get" id="search-form">
        <input
          type="search"
          name="q"
          placeholder={t('search.placeholder', lang)}
          class="search-input"
          aria-label={t('nav.search', lang)}
          id="search-input"
        />
        <button type="submit" class="btn btn-primary">{t('nav.search', lang)}</button>
      </form>
    </div>

    <details class="filter-panel" id="filter-panel">
      <summary class="filter-toggle">{t('filter.title', lang)}</summary>
      <div class="filter-grid">
        <div class="filter-group">
          <label for="filter-type">{t('filter.type', lang)}</label>
          <select id="filter-type">
            <option value="">{t('filter.type.all', lang)}</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="filter-source">{t('filter.source', lang)}</label>
          <select id="filter-source">
            <option value="">{t('filter.source.all', lang)}</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="filter-year">{t('filter.year', lang)}</label>
          <select id="filter-year">
            <option value="">{t('filter.year.all', lang)}</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="filter-signatory">{t('filter.signatory', lang)}</label>
          <select id="filter-signatory">
            <option value="">{t('filter.signatory.all', lang)}</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="filter-role">{t('filter.role', lang)}</label>
          <select id="filter-role">
            <option value="">{t('filter.role.all', lang)}</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="filter-scope">{t('filter.scope', lang)}</label>
          <select id="filter-scope">
            <option value="">{t('filter.scope.all', lang)}</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="filter-territory">{t('filter.territory', lang)}</label>
          <select id="filter-territory">
            <option value="">{t('filter.territory.all', lang)}</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="filter-temporality">{t('filter.temporality', lang)}</label>
          <select id="filter-temporality">
            <option value="">{t('filter.temporality.all', lang)}</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="filter-doctype">{t('filter.docType', lang)}</label>
          <select id="filter-doctype">
            <option value="">{t('filter.docType.all', lang)}</option>
          </select>
        </div>
        <div class="filter-group filter-actions">
          <button type="button" id="clear-filters" class="btn btn-secondary">{t('filter.clear', lang)}</button>
        </div>
      </div>
    </details>

    <div class="results-area" id="results-area">
      <p class="searching" id="searching-msg" style="display:none;">{t('search.searching', lang)}</p>
      <p class="no-results" id="no-results-msg" style="display:none;"></p>
      <div class="total-occurrences" id="total-occurrences" style="display:none;"></div>
      <p class="results-count" id="results-count" style="display:none;"></p>
      <div id="results-list"></div>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ base, lang: 'va', lawPath: 'llei', typeLabels, tagLabels }}>
  const searchInput = document.getElementById('search-input');
  const searchForm = document.getElementById('search-form');
  const searchingMsg = document.getElementById('searching-msg');
  const noResultsMsg = document.getElementById('no-results-msg');
  const resultsCount = document.getElementById('results-count');
  const totalOccurrences = document.getElementById('total-occurrences');
  const resultsList = document.getElementById('results-list');
  const filterPanel = document.getElementById('filter-panel');

  const filterType = document.getElementById('filter-type');
  const filterSource = document.getElementById('filter-source');
  const filterYear = document.getElementById('filter-year');
  const filterSignatory = document.getElementById('filter-signatory');
  const filterRole = document.getElementById('filter-role');
  const filterScope = document.getElementById('filter-scope');
  const filterTerritory = document.getElementById('filter-territory');
  const filterTemporality = document.getElementById('filter-temporality');
  const filterDocType = document.getElementById('filter-doctype');
  const clearFiltersBtn = document.getElementById('clear-filters');

  let fullIndex = null;

  const params = new URLSearchParams(window.location.search);
  const query = params.get('q') || '';
  if (query) {
    searchInput.value = query;
  }

  loadIndex();

  searchForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const q = searchInput.value.trim();
    const url = new URL(window.location);
    if (q) url.searchParams.set('q', q);
    else url.searchParams.delete('q');
    window.history.pushState({}, '', url);
    applySearchAndFilters();
  });

  [filterType, filterSource, filterYear, filterSignatory, filterRole, filterScope, filterTerritory, filterTemporality, filterDocType].forEach(el => {
    el.addEventListener('change', applySearchAndFilters);
  });

  clearFiltersBtn.addEventListener('click', () => {
    filterType.value = '';
    filterSource.value = '';
    filterYear.value = '';
    filterSignatory.value = '';
    filterRole.value = '';
    filterScope.value = '';
    filterTerritory.value = '';
    filterTemporality.value = '';
    filterDocType.value = '';
    applySearchAndFilters();
  });

  async function loadIndex() {
    searchingMsg.style.display = 'block';
    try {
      const res = await fetch(`${base}api/search-index-${lang}.json`);
      fullIndex = await res.json();
      populateFilterOptions(fullIndex);
      searchingMsg.style.display = 'none';
      if (query) applySearchAndFilters();
    } catch (err) {
      searchingMsg.style.display = 'none';
      noResultsMsg.textContent = "Error en carregar l'índex de cerca.";
      noResultsMsg.style.display = 'block';
    }
  }

  function populateFilterOptions(index) {
    const types = new Set();
    const sources = new Set();
    const years = new Set();
    const names = new Set();
    const roles = new Set();
    const scopes = new Set();
    const territories = new Set();
    const temporalities = new Set();
    const docTypes = new Set();

    for (const law of index) {
      types.add(law.type);
      sources.add(law.source);
      years.add(law.year);
      if (law.scope) scopes.add(law.scope);
      if (law.territory) territories.add(law.territory);
      if (law.temporality) temporalities.add(law.temporality.type);
      if (law.docType) docTypes.add(law.docType);
      for (const s of law.signatories) {
        names.add(s.name);
        roles.add(s.role);
      }
    }

    function addOpts(selectEl, values, labelMap, prefix) {
      for (const v of [...values].sort()) {
        const opt = document.createElement('option');
        opt.value = v;
        opt.textContent = (labelMap && labelMap[prefix ? prefix + v : v]) || v;
        selectEl.appendChild(opt);
      }
    }

    addOpts(filterType, types, typeLabels, '');
    addOpts(filterSource, sources, null, '');
    for (const y of [...years].sort((a, b) => b - a)) {
      const opt = document.createElement('option');
      opt.value = y;
      opt.textContent = y;
      filterYear.appendChild(opt);
    }
    addOpts(filterSignatory, names, null, '');
    addOpts(filterRole, roles, null, '');
    addOpts(filterScope, scopes, tagLabels, 'scope.');
    addOpts(filterTerritory, territories, tagLabels, 'territory.');
    addOpts(filterTemporality, temporalities, tagLabels, 'temporality.');
    addOpts(filterDocType, docTypes, tagLabels, 'docType.');
  }

  function applySearchAndFilters() {
    if (!fullIndex) return;

    const q = searchInput.value.trim();
    const fType = filterType.value;
    const fSource = filterSource.value;
    const fYear = filterYear.value;
    const fSignatory = filterSignatory.value;
    const fRole = filterRole.value;
    const fScope = filterScope.value;
    const fTerritory = filterTerritory.value;
    const fTemporality = filterTemporality.value;
    const fDocType = filterDocType.value;
    const hasFilters = fType || fSource || fYear || fSignatory || fRole || fScope || fTerritory || fTemporality || fDocType;

    if (!q && !hasFilters) {
      noResultsMsg.style.display = 'none';
      resultsCount.style.display = 'none';
      resultsList.innerHTML = '';
      return;
    }

    let results;
    if (q) {
      results = search(fullIndex, q);
    } else {
      results = fullIndex.map(law => ({
        ...law,
        titleMatch: false,
        fragments: [],
      }));
    }

    if (fType) results = results.filter(r => r.type === fType);
    if (fSource) results = results.filter(r => r.source === fSource);
    if (fYear) results = results.filter(r => String(r.year) === fYear);
    if (fSignatory) results = results.filter(r =>
      r.signatories && r.signatories.some(s => s.name === fSignatory));
    if (fRole) results = results.filter(r =>
      r.signatories && r.signatories.some(s => s.role === fRole));
    if (fScope) results = results.filter(r => r.scope === fScope);
    if (fTerritory) results = results.filter(r => r.territory === fTerritory);
    if (fTemporality) results = results.filter(r => r.temporality && r.temporality.type === fTemporality);
    if (fDocType) results = results.filter(r => r.docType === fDocType);

    renderResults(results, q);
  }

  function normalize(str) {
    return str.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
  }

  function search(index, q) {
    const terms = normalize(q).split(/\s+/).filter(Boolean);
    const results = [];

    for (const law of index) {
      const titleNorm = normalize(law.title);
      const titleShortNorm = normalize(law.titleShort);
      const titleMatch = terms.every(t => titleNorm.includes(t) || titleShortNorm.includes(t));

      const matchingFragments = [];
      for (const frag of law.fragments) {
        const fragNorm = normalize(frag.text);
        const fragTitleNorm = normalize(frag.title);
        if (terms.every(t => fragNorm.includes(t) || fragTitleNorm.includes(t))) {
          matchingFragments.push(frag);
        }
      }

      if (titleMatch || matchingFragments.length > 0) {
        results.push({
          ...law,
          titleMatch,
          fragments: matchingFragments,
        });
      }
    }

    return results;
  }

  function highlightText(text, q) {
    if (!q) return text;
    const terms = normalize(q).split(/\s+/).filter(Boolean);
    const normText = normalize(text);
    const ranges = [];
    for (const term of terms) {
      let idx = 0;
      while (true) {
        const pos = normText.indexOf(term, idx);
        if (pos === -1) break;
        ranges.push([pos, pos + term.length]);
        idx = pos + 1;
      }
    }
    if (ranges.length === 0) return text;
    ranges.sort((a, b) => a[0] - b[0]);
    const merged = [ranges[0]];
    for (let i = 1; i < ranges.length; i++) {
      const last = merged[merged.length - 1];
      if (ranges[i][0] <= last[1]) last[1] = Math.max(last[1], ranges[i][1]);
      else merged.push(ranges[i]);
    }
    let result = '';
    let pos = 0;
    for (const [start, end] of merged) {
      result += text.slice(pos, start);
      result += '<mark>' + text.slice(start, end) + '</mark>';
      pos = end;
    }
    return result + text.slice(pos);
  }

  function getSnippet(text, q, maxLen = 200) {
    if (!q) return text.slice(0, maxLen) + (text.length > maxLen ? '...' : '');
    const terms = normalize(q).split(/\s+/).filter(Boolean);
    const normText = normalize(text);
    let firstIdx = normText.length;
    for (const term of terms) {
      const idx = normText.indexOf(term);
      if (idx !== -1 && idx < firstIdx) firstIdx = idx;
    }
    const start = Math.max(0, firstIdx - 60);
    const end = Math.min(text.length, start + maxLen);
    let snippet = text.slice(start, end);
    if (start > 0) snippet = '...' + snippet;
    if (end < text.length) snippet = snippet + '...';
    return highlightText(snippet, q);
  }

  const vigencyLabels = {
    vigente: 'Vigent',
    vigente_parcial: 'Vigent amb modificacions',
    derogada_parcial: 'Derogada parcialment',
    derogada: 'Derogada',
  };

  function renderResults(results, q) {
    resultsList.innerHTML = '';
    noResultsMsg.style.display = 'none';
    resultsCount.style.display = 'none';
    totalOccurrences.style.display = 'none';

    if (results.length === 0) {
      noResultsMsg.textContent = q
        ? `No s'han trobat resultats per a "${q}"`
        : "No s'han trobat resultats amb els filtres seleccionats.";
      noResultsMsg.style.display = 'block';
      return;
    }

    resultsCount.textContent = `${results.length} disposició(ns) amb resultats`;
    resultsCount.style.display = 'block';

    if (q) {
      const total = results.reduce((sum, r) => sum + r.fragments.length, 0);
      totalOccurrences.innerHTML = `<span class="total-number">${total.toLocaleString('ca-ES')}</span> <span class="total-label">aparició${total !== 1 ? 'ns' : ''} en tota la base de dades</span>`;
      totalOccurrences.style.display = 'block';
    }

    for (const r of results) {
      const card = document.createElement('div');
      card.className = 'result-card';

      const titleHtml = highlightText(r.titleShort, q);
      const lawUrl = `${base}${lang}/${lawPath}/${r.slug}/`;
      const vigLabel = vigencyLabels[r.vigpiracy] || r.vigpiracy;

      let fragmentsHtml = '';
      const maxFragments = 3;
      for (const frag of r.fragments.slice(0, maxFragments)) {
        const snippet = getSnippet(frag.text, q);
        fragmentsHtml += `
          <div class="result-fragment">
            <a href="${lawUrl}#${frag.id}" class="fragment-link">${highlightText(frag.title, q)}</a>
            <p class="fragment-snippet">${snippet}</p>
          </div>`;
      }
      if (r.fragments.length > maxFragments) {
        const remaining = r.fragments.slice(maxFragments);
        let hiddenHtml = '';
        for (const frag of remaining) {
          const snippet = getSnippet(frag.text, q);
          hiddenHtml += `
            <div class="result-fragment">
              <a href="${lawUrl}#${frag.id}" class="fragment-link">${highlightText(frag.title, q)}</a>
              <p class="fragment-snippet">${snippet}</p>
            </div>`;
        }
        fragmentsHtml += `
          <div class="hidden-fragments" style="display:none;">${hiddenHtml}</div>
          <p class="more-fragments"><button class="expand-fragments" type="button">...i ${remaining.length} coincidència${remaining.length !== 1 ? 'es' : ''} més</button></p>`;
      }

      const scopeTag = tagLabels['scope.' + r.scope] || r.scope || '';
      const territoryTag = tagLabels['territory.' + r.territory] || r.territory || '';
      const tempType = r.temporality ? r.temporality.type : 'permanente';
      const tempTag = tempType === 'anual' && r.temporality.schoolYear
        ? `Anual ${r.temporality.schoolYear}`
        : tagLabels['temporality.' + tempType] || tempType;
      const docTag = r.docType !== 'normativa' ? (tagLabels['docType.' + r.docType] || '') : '';

      card.innerHTML = `
        <div class="result-header">
          <a href="${lawUrl}" class="result-title">${titleHtml}</a>
          <span class="vigency-badge vigency-${r.vigpiracy}">${vigLabel}</span>
        </div>
        <p class="result-meta">${typeLabels[r.type] || r.type} — ${r.date}</p>
        <div class="result-tags">
          <span class="result-tag tag-scope-${r.scope}">${scopeTag}</span>
          <span class="result-tag tag-territory-${r.territory}">${territoryTag}</span>
          <span class="result-tag tag-temporality-${tempType}">${tempTag}</span>
          ${docTag ? `<span class="result-tag tag-doctype-${r.docType}">${docTag}</span>` : ''}
        </div>
        ${r.titleMatch ? '<p class="match-type">Coincidència en títol</p>' : ''}
        ${fragmentsHtml}
      `;

      resultsList.appendChild(card);
    }
  }

  resultsList.addEventListener('click', (e) => {
    const btn = e.target.closest('.expand-fragments');
    if (!btn) return;
    const moreP = btn.closest('.more-fragments');
    const hiddenDiv = moreP.previousElementSibling;
    hiddenDiv.style.display = 'block';
    moreP.remove();
  });
</script>

<style>
  .search-page {
    padding: var(--space-xl) 0;
    max-width: 800px;
  }

  h1 {
    font-size: 1.8rem;
    color: var(--color-primary);
    margin-bottom: var(--space-lg);
  }

  .search-box {
    margin-bottom: var(--space-md);
  }

  .search-box form {
    display: flex;
    gap: var(--space-sm);
  }

  .search-input {
    flex: 1;
    padding: var(--space-sm) var(--space-md);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: 1rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .search-input:focus {
    border-color: var(--color-primary);
  }

  .filter-panel {
    margin-bottom: var(--space-xl);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-secondary);
  }

  .filter-toggle {
    padding: var(--space-sm) var(--space-md);
    cursor: pointer;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-primary);
    user-select: none;
  }

  .filter-toggle:hover {
    color: var(--color-primary-dark);
  }

  .filter-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-sm) var(--space-md);
    padding: 0 var(--space-md) var(--space-md);
  }

  .filter-group label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text-muted);
    margin-bottom: 4px;
  }

  .filter-group select {
    width: 100%;
    padding: 6px 8px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    background: white;
  }

  .filter-actions {
    display: flex;
    align-items: flex-end;
  }

  .btn-secondary {
    padding: 6px 12px;
    font-size: 0.8rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: white;
    cursor: pointer;
    color: var(--color-text-secondary);
  }

  .btn-secondary:hover {
    background: var(--color-bg-secondary);
    color: var(--color-text);
  }

  .searching {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .no-results {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .results-count {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .total-occurrences {
    margin-bottom: var(--space-md);
    line-height: 1.2;
  }

  .total-number {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-primary);
  }

  .total-label {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
  }
</style>

<style is:global>
  .result-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-md);
    margin-bottom: var(--space-md);
    transition: box-shadow 0.2s;
  }

  .result-card:hover {
    box-shadow: var(--shadow-md);
  }

  .result-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-bottom: var(--space-xs);
  }

  .result-title {
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-primary);
    text-decoration: none;
  }

  .result-title:hover {
    text-decoration: underline;
  }

  .result-meta {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .match-type {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    font-style: italic;
    margin-bottom: var(--space-xs);
  }

  .result-fragment {
    padding-left: var(--space-md);
    border-left: 2px solid var(--color-border);
    margin-bottom: var(--space-sm);
  }

  .fragment-link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }

  .fragment-link:hover {
    text-decoration: underline;
  }

  .fragment-snippet {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
    margin-top: 2px;
  }

  .fragment-snippet mark {
    background: #fef3c7;
    color: inherit;
    padding: 0 2px;
    border-radius: 2px;
  }

  .result-card .vigency-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 3px;
    white-space: nowrap;
    letter-spacing: 0.02em;
  }

  .result-card .vigency-vigente { background: #c6f6d5; color: #22543d; }
  .result-card .vigency-vigente_parcial { background: #fefcbf; color: #744210; }
  .result-card .vigency-derogada_parcial { background: #feebc8; color: #7b341e; }
  .result-card .vigency-derogada { background: #fed7d7; color: #742a2a; }

  .result-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-bottom: 6px;
  }
  .result-tag {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
