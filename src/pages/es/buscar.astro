---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';

const lang = 'es' as const;
const base = import.meta.env.BASE_URL;

const typeLabels: Record<string, string> = {
  decreto: t('filter.type.decreto', lang),
  orden: t('filter.type.orden', lang),
  resolucion: t('filter.type.resolucion', lang),
  ley: t('filter.type.ley', lang),
  ley_organica: t('filter.type.ley_organica', lang),
  real_decreto: t('filter.type.real_decreto', lang),
  correccion_errores: t('filter.type.correccion_errores', lang),
};
---

<BaseLayout lang={lang} title={t('search.results', lang)}>
  <div class="container search-page">
    <h1>{t('search.results', lang)}</h1>

    <div class="search-box">
      <form action={`${base}es/buscar/`} method="get" id="search-form">
        <input
          type="search"
          name="q"
          placeholder={t('search.placeholder', lang)}
          class="search-input"
          aria-label={t('nav.search', lang)}
          id="search-input"
        />
        <button type="submit" class="btn btn-primary">{t('nav.search', lang)}</button>
      </form>
    </div>

    <details class="filter-panel" id="filter-panel">
      <summary class="filter-toggle">{t('filter.title', lang)}</summary>
      <div class="filter-grid">
        <div class="filter-group">
          <label for="filter-type">{t('filter.type', lang)}</label>
          <select id="filter-type">
            <option value="">{t('filter.type.all', lang)}</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="filter-source">{t('filter.source', lang)}</label>
          <select id="filter-source">
            <option value="">{t('filter.source.all', lang)}</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="filter-year">{t('filter.year', lang)}</label>
          <select id="filter-year">
            <option value="">{t('filter.year.all', lang)}</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="filter-signatory">{t('filter.signatory', lang)}</label>
          <select id="filter-signatory">
            <option value="">{t('filter.signatory.all', lang)}</option>
          </select>
        </div>
        <div class="filter-group">
          <label for="filter-role">{t('filter.role', lang)}</label>
          <select id="filter-role">
            <option value="">{t('filter.role.all', lang)}</option>
          </select>
        </div>
        <div class="filter-group filter-actions">
          <button type="button" id="clear-filters" class="btn btn-secondary">{t('filter.clear', lang)}</button>
        </div>
      </div>
    </details>

    <div class="results-area" id="results-area">
      <p class="searching" id="searching-msg" style="display:none;">{t('search.searching', lang)}</p>
      <p class="no-results" id="no-results-msg" style="display:none;"></p>
      <p class="results-count" id="results-count" style="display:none;"></p>
      <div id="results-list"></div>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ base, lang: 'es', lawPath: 'ley', typeLabels }}>
  const searchInput = document.getElementById('search-input');
  const searchForm = document.getElementById('search-form');
  const searchingMsg = document.getElementById('searching-msg');
  const noResultsMsg = document.getElementById('no-results-msg');
  const resultsCount = document.getElementById('results-count');
  const resultsList = document.getElementById('results-list');
  const filterPanel = document.getElementById('filter-panel');

  const filterType = document.getElementById('filter-type');
  const filterSource = document.getElementById('filter-source');
  const filterYear = document.getElementById('filter-year');
  const filterSignatory = document.getElementById('filter-signatory');
  const filterRole = document.getElementById('filter-role');
  const clearFiltersBtn = document.getElementById('clear-filters');

  let fullIndex = null;

  // Get query from URL
  const params = new URLSearchParams(window.location.search);
  const query = params.get('q') || '';
  if (query) {
    searchInput.value = query;
  }

  // Load index once, then search/filter
  loadIndex();

  searchForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const q = searchInput.value.trim();
    const url = new URL(window.location);
    if (q) url.searchParams.set('q', q);
    else url.searchParams.delete('q');
    window.history.pushState({}, '', url);
    applySearchAndFilters();
  });

  [filterType, filterSource, filterYear, filterSignatory, filterRole].forEach(el => {
    el.addEventListener('change', applySearchAndFilters);
  });

  clearFiltersBtn.addEventListener('click', () => {
    filterType.value = '';
    filterSource.value = '';
    filterYear.value = '';
    filterSignatory.value = '';
    filterRole.value = '';
    applySearchAndFilters();
  });

  async function loadIndex() {
    searchingMsg.style.display = 'block';
    try {
      const res = await fetch(`${base}api/search-index-${lang}.json`);
      fullIndex = await res.json();
      populateFilterOptions(fullIndex);
      searchingMsg.style.display = 'none';
      if (query) applySearchAndFilters();
    } catch (err) {
      searchingMsg.style.display = 'none';
      noResultsMsg.textContent = 'Error al cargar el índice de búsqueda.';
      noResultsMsg.style.display = 'block';
    }
  }

  function populateFilterOptions(index) {
    const types = new Set();
    const sources = new Set();
    const years = new Set();
    const names = new Set();
    const roles = new Set();

    for (const law of index) {
      types.add(law.type);
      sources.add(law.source);
      years.add(law.year);
      for (const s of law.signatories) {
        names.add(s.name);
        roles.add(s.role);
      }
    }

    for (const t of [...types].sort()) {
      const opt = document.createElement('option');
      opt.value = t;
      opt.textContent = typeLabels[t] || t;
      filterType.appendChild(opt);
    }
    for (const s of [...sources].sort()) {
      const opt = document.createElement('option');
      opt.value = s;
      opt.textContent = s;
      filterSource.appendChild(opt);
    }
    for (const y of [...years].sort((a, b) => b - a)) {
      const opt = document.createElement('option');
      opt.value = y;
      opt.textContent = y;
      filterYear.appendChild(opt);
    }
    for (const n of [...names].sort()) {
      const opt = document.createElement('option');
      opt.value = n;
      opt.textContent = n;
      filterSignatory.appendChild(opt);
    }
    for (const r of [...roles].sort()) {
      const opt = document.createElement('option');
      opt.value = r;
      opt.textContent = r;
      filterRole.appendChild(opt);
    }
  }

  function applySearchAndFilters() {
    if (!fullIndex) return;

    const q = searchInput.value.trim();
    const fType = filterType.value;
    const fSource = filterSource.value;
    const fYear = filterYear.value;
    const fSignatory = filterSignatory.value;
    const fRole = filterRole.value;
    const hasFilters = fType || fSource || fYear || fSignatory || fRole;

    // If no query and no filters, show nothing
    if (!q && !hasFilters) {
      noResultsMsg.style.display = 'none';
      resultsCount.style.display = 'none';
      resultsList.innerHTML = '';
      return;
    }

    // Step 1: text search (or all if no query)
    let results;
    if (q) {
      results = search(fullIndex, q);
    } else {
      results = fullIndex.map(law => ({
        ...law,
        titleMatch: false,
        fragments: [],
      }));
    }

    // Step 2: apply filters
    if (fType) results = results.filter(r => r.type === fType);
    if (fSource) results = results.filter(r => r.source === fSource);
    if (fYear) results = results.filter(r => String(r.year) === fYear);
    if (fSignatory) results = results.filter(r =>
      r.signatories && r.signatories.some(s => s.name === fSignatory));
    if (fRole) results = results.filter(r =>
      r.signatories && r.signatories.some(s => s.role === fRole));

    renderResults(results, q);
  }

  function normalize(str) {
    return str.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
  }

  function search(index, q) {
    const terms = normalize(q).split(/\s+/).filter(Boolean);
    const results = [];

    for (const law of index) {
      const titleNorm = normalize(law.title);
      const titleShortNorm = normalize(law.titleShort);
      const titleMatch = terms.every(t => titleNorm.includes(t) || titleShortNorm.includes(t));

      const matchingFragments = [];
      for (const frag of law.fragments) {
        const fragNorm = normalize(frag.text);
        const fragTitleNorm = normalize(frag.title);
        if (terms.every(t => fragNorm.includes(t) || fragTitleNorm.includes(t))) {
          matchingFragments.push(frag);
        }
      }

      if (titleMatch || matchingFragments.length > 0) {
        results.push({
          ...law,
          titleMatch,
          fragments: matchingFragments,
        });
      }
    }

    return results;
  }

  function highlightText(text, q) {
    if (!q) return text;
    const terms = normalize(q).split(/\s+/).filter(Boolean);
    let result = text;
    for (const term of terms) {
      const regex = new RegExp(`(${term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
      result = result.replace(regex, '<mark>$1</mark>');
    }
    return result;
  }

  function getSnippet(text, q, maxLen = 200) {
    if (!q) return text.slice(0, maxLen) + (text.length > maxLen ? '...' : '');
    const terms = normalize(q).split(/\s+/).filter(Boolean);
    const normText = normalize(text);
    let firstIdx = normText.length;
    for (const term of terms) {
      const idx = normText.indexOf(term);
      if (idx !== -1 && idx < firstIdx) firstIdx = idx;
    }
    const start = Math.max(0, firstIdx - 60);
    const end = Math.min(text.length, start + maxLen);
    let snippet = text.slice(start, end);
    if (start > 0) snippet = '...' + snippet;
    if (end < text.length) snippet = snippet + '...';
    return highlightText(snippet, q);
  }

  const vigencyLabels = {
    vigente: 'Vigente',
    vigente_parcial: 'Vigente con modificaciones',
    derogada_parcial: 'Derogada parcialmente',
    derogada: 'Derogada',
  };

  function renderResults(results, q) {
    resultsList.innerHTML = '';
    noResultsMsg.style.display = 'none';
    resultsCount.style.display = 'none';

    if (results.length === 0) {
      noResultsMsg.textContent = q
        ? `No se encontraron resultados para "${q}"`
        : 'No se encontraron resultados con los filtros seleccionados.';
      noResultsMsg.style.display = 'block';
      return;
    }

    resultsCount.textContent = `${results.length} resultado(s) encontrado(s)`;
    resultsCount.style.display = 'block';

    for (const r of results) {
      const card = document.createElement('div');
      card.className = 'result-card';

      const titleHtml = highlightText(r.titleShort, q);
      const lawUrl = `${base}${lang}/${lawPath}/${r.slug}/`;
      const vigLabel = vigencyLabels[r.vigpiracy] || r.vigpiracy;

      let fragmentsHtml = '';
      const maxFragments = 3;
      const shown = r.fragments.slice(0, maxFragments);
      for (const frag of shown) {
        const snippet = getSnippet(frag.text, q);
        fragmentsHtml += `
          <div class="result-fragment">
            <a href="${lawUrl}#${frag.id}" class="fragment-link">${highlightText(frag.title, q)}</a>
            <p class="fragment-snippet">${snippet}</p>
          </div>`;
      }
      if (r.fragments.length > maxFragments) {
        fragmentsHtml += `<p class="more-fragments">...y ${r.fragments.length - maxFragments} coincidencia(s) más</p>`;
      }

      card.innerHTML = `
        <div class="result-header">
          <a href="${lawUrl}" class="result-title">${titleHtml}</a>
          <span class="vigency-badge vigency-${r.vigpiracy}">${vigLabel}</span>
        </div>
        <p class="result-meta">${typeLabels[r.type] || r.type} — ${r.date}</p>
        ${r.titleMatch ? '<p class="match-type">Coincidencia en título</p>' : ''}
        ${fragmentsHtml}
      `;

      resultsList.appendChild(card);
    }
  }
</script>

<style>
  .search-page {
    padding: var(--space-xl) 0;
    max-width: 800px;
  }

  h1 {
    font-size: 1.8rem;
    color: var(--color-primary);
    margin-bottom: var(--space-lg);
  }

  .search-box {
    margin-bottom: var(--space-md);
  }

  .search-box form {
    display: flex;
    gap: var(--space-sm);
  }

  .search-input {
    flex: 1;
    padding: var(--space-sm) var(--space-md);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: 1rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .search-input:focus {
    border-color: var(--color-primary);
  }

  .filter-panel {
    margin-bottom: var(--space-xl);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-secondary);
  }

  .filter-toggle {
    padding: var(--space-sm) var(--space-md);
    cursor: pointer;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-primary);
    user-select: none;
  }

  .filter-toggle:hover {
    color: var(--color-primary-dark);
  }

  .filter-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-sm) var(--space-md);
    padding: 0 var(--space-md) var(--space-md);
  }

  .filter-group label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text-muted);
    margin-bottom: 4px;
  }

  .filter-group select {
    width: 100%;
    padding: 6px 8px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    background: white;
  }

  .filter-actions {
    display: flex;
    align-items: flex-end;
  }

  .btn-secondary {
    padding: 6px 12px;
    font-size: 0.8rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: white;
    cursor: pointer;
    color: var(--color-text-secondary);
  }

  .btn-secondary:hover {
    background: var(--color-bg-secondary);
    color: var(--color-text);
  }

  .searching {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .no-results {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .results-count {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }
</style>

<style is:global>
  .result-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-md);
    margin-bottom: var(--space-md);
    transition: box-shadow 0.2s;
  }

  .result-card:hover {
    box-shadow: var(--shadow-md);
  }

  .result-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-bottom: var(--space-xs);
  }

  .result-title {
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-primary);
    text-decoration: none;
  }

  .result-title:hover {
    text-decoration: underline;
  }

  .result-meta {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .match-type {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    font-style: italic;
    margin-bottom: var(--space-xs);
  }

  .result-fragment {
    padding-left: var(--space-md);
    border-left: 2px solid var(--color-border);
    margin-bottom: var(--space-sm);
  }

  .fragment-link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }

  .fragment-link:hover {
    text-decoration: underline;
  }

  .fragment-snippet {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
    margin-top: 2px;
  }

  .fragment-snippet mark {
    background: #fef3c7;
    color: inherit;
    padding: 0 2px;
    border-radius: 2px;
  }

  .result-card .vigency-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 3px;
    white-space: nowrap;
    letter-spacing: 0.02em;
  }

  .result-card .vigency-vigente { background: #c6f6d5; color: #22543d; }
  .result-card .vigency-vigente_parcial { background: #fefcbf; color: #744210; }
  .result-card .vigency-derogada_parcial { background: #feebc8; color: #7b341e; }
  .result-card .vigency-derogada { background: #fed7d7; color: #742a2a; }

  .more-fragments {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-style: italic;
    padding-left: var(--space-md);
  }
</style>
