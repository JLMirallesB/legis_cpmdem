---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LawCatalog from '../../components/LawCatalog.astro';
import { t } from '../../i18n/utils';

const lang = 'es' as const;
---

<BaseLayout lang={lang}>
  <div class="container hero">
    <img class="page-icon" src={`${import.meta.env.BASE_URL}icons/icon-192.png`} alt="" width="64" height="64" />
    <h1>{t('catalog.title', lang)}</h1>
    <p class="subtitle">{t('catalog.subtitle', lang)}</p>

    <div class="search-box">
      <form action={`${import.meta.env.BASE_URL}es/buscar/`} method="get">
        <input
          type="search"
          name="q"
          placeholder={t('search.placeholder', lang)}
          class="search-input"
          aria-label={t('nav.search', lang)}
        />
        <button type="submit" class="btn btn-primary">{t('nav.search', lang)}</button>
      </form>
      <a href={`${import.meta.env.BASE_URL}es/changelog/`} class="changelog-link">
        &#128240; {t('nav.changelog', lang)}
      </a>
    </div>
  </div>

  <div class="container catalog-container">
    <LawCatalog lang={lang} />
  </div>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-2xl);
  }

  .page-icon {
    display: block;
    margin: 0 auto var(--space-md);
    border-radius: var(--radius-md);
  }

  h1 {
    font-size: 2rem;
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
  }

  .subtitle {
    color: var(--color-text-secondary);
    font-size: 1.1rem;
    margin-bottom: var(--space-xl);
  }

  .search-box {
    max-width: 600px;
    margin: 0 auto;
  }

  .search-box form {
    display: flex;
    gap: var(--space-sm);
  }

  .search-input {
    flex: 1;
    padding: var(--space-sm) var(--space-md);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: 1rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .search-input:focus {
    border-color: var(--color-primary);
  }

  .changelog-link {
    display: inline-block;
    margin-top: var(--space-sm);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .changelog-link:hover {
    color: var(--color-primary);
  }

  .catalog-container {
    padding-bottom: var(--space-2xl);
  }
</style>
