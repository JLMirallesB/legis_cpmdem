---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';
import changelog from '../../../data/changelog.json';

const lang = 'es' as const;
const base = import.meta.env.BASE_URL;

const TYPE_LABELS = {
  nuevo: 'novedad(es)',
  mejora: 'mejora(s)',
  corregido: 'corrección(es)',
  actualizado: 'actualización(es)',
  eliminado: 'eliminación(es)',
} as Record<string, string>;

// Precompute announce texts for each release
const releases = changelog.map((release) => {
  const grouped = {} as Record<string, number>;
  for (const entry of release.entries.es) {
    grouped[entry.type] = (grouped[entry.type] || 0) + 1;
  }
  const summary = Object.entries(grouped)
    .map(([type, count]) => `${count} ${TYPE_LABELS[type] || type}`)
    .join(', ');
  const dateStr = new Date(release.date).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
  const announceText = t('changelog.announce_template', lang, { version: release.version, date: dateStr, summary });
  return { ...release, dateStr, announceText };
});
---

<BaseLayout lang={lang} title={t('changelog.title', lang)}>
  <div class="container changelog-page">
    <img class="page-icon" src={`${base}icons/icon-192.png`} alt="" width="48" height="48" />
    <div class="changelog-header">
      <div>
        <h1>{t('changelog.title', lang)}</h1>
        <p class="subtitle">{t('changelog.subtitle', lang)}</p>
      </div>
      <a href={`${base}rss-es.xml`} class="rss-btn" target="_blank" rel="noopener" aria-label={t('changelog.subscribe', lang)}>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="6.18" cy="17.82" r="2.18"/><path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/></svg>
        {t('changelog.subscribe', lang)}
      </a>
    </div>

    {releases.length === 0 ? (
      <p class="empty">{t('changelog.empty', lang)}</p>
    ) : (
      <div class="changelog-list">
        {releases.map((release) => (
            <article class="release">
              <header class="release-header">
                <div class="release-title">
                  <h2>{t('changelog.version', lang, { version: release.version })}</h2>
                  <time datetime={release.date}>{release.dateStr}</time>
                </div>
                <button class="announce-btn" data-text={release.announceText} aria-label={t('changelog.announce', lang)}>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                  {t('changelog.announce', lang)}
                </button>
              </header>
              <ul class="release-entries">
                {release.entries.es.map((entry) => (
                  <li>
                    <span class={`entry-badge entry-${entry.type}`}>{entry.type}</span>
                    {entry.description}
                  </li>
                ))}
              </ul>
            </article>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<script>
  document.querySelectorAll('.announce-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = (btn as HTMLElement).dataset.text || '';
      await navigator.clipboard.writeText(text);
      const original = btn.innerHTML;
      btn.textContent = '\u00a1Copiado!';
      btn.classList.add('copied');
      setTimeout(() => {
        btn.innerHTML = original;
        btn.classList.remove('copied');
      }, 2000);
    });
  });
</script>

<style>
  .changelog-page {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-xl);
    max-width: 800px;
  }

  .page-icon {
    display: block;
    margin: 0 auto var(--space-sm);
    border-radius: var(--radius-md);
  }

  .changelog-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  h1 {
    font-size: 2rem;
    color: var(--color-primary);
    margin-bottom: var(--space-xs);
  }

  .subtitle {
    color: var(--color-text-secondary);
  }

  .rss-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: #f97316;
    color: white;
    border-radius: var(--radius-sm);
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.2s;
  }

  .rss-btn:hover {
    background: #ea580c;
    color: white;
    text-decoration: none;
  }

  .empty {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .release {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-border);
  }

  .release:last-child {
    border-bottom: none;
  }

  .release-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .release-title {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
  }

  .release-title h2 {
    font-size: 1.3rem;
    color: var(--color-primary);
  }

  .release-title time {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .announce-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    background: var(--color-bg-secondary, #f1f5f9);
    color: var(--color-text-secondary, #64748b);
    border: 1px solid var(--color-border, #e2e8f0);
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s;
  }

  .announce-btn:hover {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  .announce-btn.copied {
    background: #22543d;
    color: white;
    border-color: #22543d;
  }

  .release-entries {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .release-entries li {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    line-height: 1.5;
  }

  .entry-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    padding: 1px 6px;
    border-radius: 3px;
    white-space: nowrap;
  }

  .entry-nuevo {
    background: #c6f6d5;
    color: #22543d;
  }

  .entry-mejora {
    background: #e9d5ff;
    color: #5b21b6;
  }

  .entry-actualizado {
    background: #bee3f8;
    color: #2a4365;
  }

  .entry-corregido {
    background: #fed7d7;
    color: #742a2a;
  }

  .entry-eliminado {
    background: #e2e8f0;
    color: #4a5568;
  }

  @media (max-width: 640px) {
    .changelog-header {
      flex-direction: column;
    }
    .release-header {
      flex-direction: column;
      gap: var(--space-sm);
    }
  }
</style>
