---
import type { Lang, FormModel } from '../lib/types';
import { t } from '../i18n/utils';

interface Props {
  models: FormModel[];
  lang: Lang;
}

const { models, lang } = Astro.props;
const base = import.meta.env.BASE_URL;

/** Resolve pdfUrl: absolute URLs (https:// or //) pass through; relative paths get BASE_URL prepended */
function resolveUrl(url: string): string {
  if (url.startsWith('http') || url.startsWith('//')) return url;
  return base + url;
}
---

{models.length > 0 && (
  <div class="form-model-buttons" role="group" aria-label={t('download.form_models', lang)}>
    <span class="form-model-label">{t('download.form_models', lang)}:</span>
    {models.map((model) => (
      <a
        href={resolveUrl(model.pdfUrl)}
        target="_blank"
        rel="noopener"
        class="btn btn-form-model"
        aria-label={model.title}
        download
      >
        <span class="form-model-icon" aria-hidden="true">&#128196;</span>
        {model.title}
      </a>
    ))}
  </div>
)}

<style>
  .form-model-buttons {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-md);
    padding: var(--space-sm) var(--space-md);
    background: #fff7ed;
    border: 1px solid #fed7aa;
    border-radius: var(--radius-md);
  }

  .form-model-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: #9a3412;
    white-space: nowrap;
  }

  .btn-form-model {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: 0.82rem;
    font-weight: 600;
    padding: var(--space-xs) var(--space-sm);
    background: #ea580c;
    color: #fff;
    border: none;
    border-radius: var(--radius-sm);
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s;
  }

  .btn-form-model:hover {
    background: #c2410c;
  }

  .btn-form-model:focus-visible {
    outline: 2px solid #ea580c;
    outline-offset: 2px;
  }

  .form-model-icon {
    font-size: 0.9rem;
  }
</style>
