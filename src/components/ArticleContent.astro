---
import type { Lang, StructureNode } from '../lib/types';
import { t } from '../i18n/utils';
import { renderContent } from '../lib/content-renderer';

interface Props {
  node: StructureNode;
  lang: Lang;
}

const { node, lang } = Astro.props;
const hasVersions = node.versions && node.versions.length > 1;
const nodeId = node.id;
const copyLinkLabel = t('share.copy_link', lang);
const emailLabel = t('share.email', lang);
const waLabel = t('share.whatsapp', lang);
const saveFullLabel = t('notebook.save_full', lang);
const citeParentheticalLabel = t('cite.parenthetical', lang);
const citeReferenceLabel = t('cite.reference', lang);

const contentHtml = renderContent(node.content ?? node.versions?.[0]?.content ?? '');
---

<article class="article-block" id={nodeId}>
  <div class="article-title-row">
    <h3 class="article-title">{node.title}</h3>
    <div class="article-share-wrap">
      <button
        class="article-share-btn"
        data-article-id={nodeId}
        aria-label="Compartir"
        title="Compartir"
        type="button"
      >&#8942;</button>
      <div class="article-share-popover" id={`share-pop-${nodeId}`} hidden>
        <button class="share-pop-item" data-action="copy" data-id={nodeId} type="button">
          &#128279; {copyLinkLabel}
        </button>
        <a class="share-pop-item" data-action="email" data-id={nodeId} href="#">
          &#9993; {emailLabel}
        </a>
        <a class="share-pop-item" data-action="wa" data-id={nodeId} href="#">
          &#128172; {waLabel}
        </a>
        <button class="share-pop-item share-pop-divider" data-action="save-full" data-id={nodeId} type="button">
          &#128221; {saveFullLabel}
        </button>
        <button class="share-pop-item share-pop-divider share-pop-cite" data-action="cite-parenthetical" data-id={nodeId} type="button">
          &#128220; {citeParentheticalLabel}
        </button>
        <button class="share-pop-item share-pop-cite" data-action="cite-reference" data-id={nodeId} type="button">
          &#128220; {citeReferenceLabel}
        </button>
      </div>
    </div>
  </div>

  {hasVersions && (
    <div class="version-selector" data-article-id={nodeId}>
      <span class="version-indicator version-current" data-indicator-id={nodeId}></span>
      <label>
        <span class="version-label">{t('law.select_version', lang)}:</span>
        <select class="version-select">
          {node.versions!.map((v, i) => (
            <option value={v.versionId} selected={i === 0}>
              {i === 0
                ? t('law.version_current', lang)
                : t('law.version', lang, { date: new Date(v.effectiveDate).toLocaleDateString(lang === 'va' ? 'ca-ES' : 'es-ES') })
              }
              {v.modifiedBy ? ` (${v.modifiedBy.title})` : ` (${t('law.version_original', lang)})`}
            </option>
          ))}
        </select>
      </label>
    </div>
  )}

  <div class="article-text" data-article-id={nodeId} set:html={contentHtml} />

  <script define:vars={{
    nodeId,
    copiedMsg: t('share.link_copied', lang),
    savedMsg: t('notebook.saved', lang),
    citeCopiedMsg: t('cite.copied', lang),
    promoText: lang === 'va'
      ? '\n\n--\n📚 Compartit des de Legis CPMDEM, lector de legislació de Conservatoris Professionals de Música i Dansa de la Comunitat Valenciana.\nhttps://JLMirallesB.github.io/legis_cpmdem/'
      : '\n\n--\n📚 Compartido desde Legis CPMDEM, lector de legislación de Conservatorios Profesionales de Música y Danza de la Comunitat Valenciana.\nhttps://JLMirallesB.github.io/legis_cpmdem/',
  }}>
    // Article share popover
    const shareBtn = document.querySelector(`[data-article-id="${nodeId}"].article-share-btn`);
    const sharePop = document.getElementById(`share-pop-${nodeId}`);

    if (shareBtn && sharePop) {
      shareBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        sharePop.hidden = !sharePop.hidden;
      });

      sharePop.addEventListener('click', (e) => {
        const target = e.target.closest('[data-action]');
        if (!target) return;
        const action = target.getAttribute('data-action');
        const id = target.getAttribute('data-id');
        const url = window.location.href.split('#')[0] + '#' + id;
        const articleTitle = document.querySelector(`#${id} h3`)?.textContent?.trim() || id;

        if (action === 'copy') {
          e.preventDefault();
          navigator.clipboard.writeText(url).catch(() => {
            const ta = document.createElement('textarea');
            ta.value = url; ta.style.cssText = 'position:fixed;opacity:0';
            document.body.appendChild(ta); ta.select(); document.execCommand('copy');
            document.body.removeChild(ta);
          });
          // Show toast via sidebar toast element
          const toast = document.getElementById('sidebar-toast');
          if (toast) {
            toast.textContent = copiedMsg;
            toast.classList.add('visible');
            setTimeout(() => toast.classList.remove('visible'), 2000);
          }
          sharePop.hidden = true;
        } else if (action === 'email') {
          e.preventDefault();
          window.location.href = `mailto:?subject=${encodeURIComponent(articleTitle)}&body=${encodeURIComponent(url + promoText)}`;
          sharePop.hidden = true;
        } else if (action === 'wa') {
          e.preventDefault();
          window.open('https://wa.me/?text=' + encodeURIComponent(articleTitle + ' — ' + url + promoText), '_blank', 'noopener,noreferrer');
          sharePop.hidden = true;
        } else if (action === 'save-full') {
          e.preventDefault();
          const articleTextEl = document.querySelector(`#${id} .article-text`);
          const fullText = articleTextEl?.innerText?.trim() || '';
          if (fullText) {
            document.dispatchEvent(new CustomEvent('notebook:save-request', {
              detail: { text: fullText, articleId: id, articleTitle }
            }));
            // Toast (sidebar-toast is owned by LawSidebar but accessible by ID)
            const toast = document.getElementById('sidebar-toast');
            if (toast) {
              toast.textContent = savedMsg;
              toast.classList.add('visible');
              setTimeout(() => toast.classList.remove('visible'), 2000);
            }
          }
          sharePop.hidden = true;
        } else if (action === 'cite-parenthetical' || action === 'cite-reference') {
          e.preventDefault();
          // Dispatch event to get citation data from LawReaderLayout
          const citeEvt = new CustomEvent('cite:request', {
            detail: { type: action, articleId: id }
          });
          document.dispatchEvent(citeEvt);
          sharePop.hidden = true;
        }
      });

      document.addEventListener('click', (e) => {
        if (!sharePop.hidden && !sharePop.contains(e.target) && e.target !== shareBtn) {
          sharePop.hidden = true;
        }
      });
    }
  </script>

  {hasVersions && (
    <script define:vars={{ nodeId, versions: node.versions }}>
      function renderBlock(block) {
        if (block.trimStart().startsWith('|') && block.includes('|---')) {
          const lines = block.split('\n').filter(l => l.trim().startsWith('|'));
          if (lines.length < 2) return `<p>${block}</p>`;
          const parseRow = (line) => line.split('|').slice(1, -1).map(c => c.trim());
          const hdr = parseRow(lines[0]);
          let html = '<div class="table-wrapper"><table><thead><tr>' +
            hdr.map(c => `<th>${c}</th>`).join('') + '</tr></thead><tbody>';
          for (const row of lines.slice(2)) {
            const cells = parseRow(row);
            html += '<tr>' + cells.map(c => {
              const b = c.startsWith('**') && c.endsWith('**');
              const t = b ? c.slice(2,-2) : c;
              return b ? `<td><strong>${t}</strong></td>` : `<td>${t}</td>`;
            }).join('') + '</tr>';
          }
          return html + '</tbody></table></div>';
        }
        if (block.startsWith('**') && block.endsWith('**') && !block.slice(2,-2).includes('**')) {
          return `<p class="content-heading">${block.slice(2,-2)}</p>`;
        }
        return `<p>${block.replace(/\n/g, '<br>').replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>').replace(/(https?:\/\/[^\s<)]+[^\s<).,;:])/g, '<a href="$1" target="_blank" rel="noopener noreferrer">$1</a>')}</p>`;
      }

      const selector = document.querySelector(`.version-selector[data-article-id="${nodeId}"] select`);
      const textContainer = document.querySelector(`.article-text[data-article-id="${nodeId}"]`);
      const indicator = document.querySelector(`.version-indicator[data-indicator-id="${nodeId}"]`);

      if (selector && textContainer) {
        selector.addEventListener('change', (e) => {
          const selectedId = e.target.value;
          const selectedIdx = versions.findIndex((v) => v.versionId === selectedId);
          const version = versions[selectedIdx];
          if (version) {
            textContainer.innerHTML = version.content
              .split('\n\n')
              .map(renderBlock)
              .join('');
          }
          if (indicator) {
            indicator.classList.toggle('version-current', selectedIdx === 0);
            indicator.classList.toggle('version-old', selectedIdx !== 0);
          }
        });
      }
    </script>
  )}
</article>

<style>
  .article-block {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
    scroll-margin-top: calc(var(--header-height) + var(--space-md));
  }

  .article-block:last-child {
    border-bottom: none;
  }

  /* Article title row with share button */
  .article-title-row {
    display: flex;
    align-items: flex-start;
    gap: var(--space-xs);
    margin-bottom: var(--space-sm);
  }

  .article-title {
    font-size: 1.05rem;
    color: var(--color-primary);
    font-weight: 600;
    flex: 1;
    margin-bottom: 0;
  }

  .article-share-wrap {
    position: relative;
    flex-shrink: 0;
  }

  .article-share-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    color: var(--color-text-muted);
    width: 24px;
    height: 24px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.15s, background 0.15s;
    padding: 0;
    line-height: 1;
  }

  .article-block:hover .article-share-btn {
    opacity: 1;
  }

  .article-share-btn:hover {
    background: var(--color-bg-secondary);
    color: var(--color-primary);
  }

  .article-share-popover {
    position: absolute;
    right: 0;
    top: 28px;
    background: var(--color-bg-white);
    border: 1px solid var(--color-border-dark);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    z-index: 200;
    min-width: 180px;
    overflow: hidden;
  }

  :global(.share-pop-item) {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    padding: 8px 12px;
    font-size: 0.82rem;
    font-family: var(--font-sans);
    color: var(--color-text-secondary);
    text-decoration: none;
    cursor: pointer;
    background: none;
    border: none;
    width: 100%;
    text-align: left;
    transition: background 0.1s, color 0.1s;
  }

  :global(.share-pop-item:hover) {
    background: var(--color-bg-secondary);
    color: var(--color-primary);
    text-decoration: none;
  }

  :global(.share-pop-divider) {
    border-top: 1px solid var(--color-border);
    margin-top: 2px;
    padding-top: 8px;
  }

  :global(.share-pop-cite) {
    color: #744210;
    font-weight: 600;
  }

  :global(.share-pop-cite:hover) {
    background: #fefcbf;
    color: #744210;
  }

  .version-selector {
    margin-bottom: var(--space-sm);
    padding: var(--space-xs) var(--space-sm);
    background: #fffbeb;
    border: 1px solid #fef3c7;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .version-indicator {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .version-current {
    background: #38a169;
    box-shadow: 0 0 0 2px rgba(56, 161, 105, 0.3);
  }

  .version-old {
    background: #d69e2e;
    box-shadow: 0 0 0 2px rgba(214, 158, 46, 0.3);
  }

  .version-label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-right: var(--space-xs);
  }

  .version-select {
    font-size: 0.8rem;
    padding: 2px 4px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    max-width: 100%;
  }

  .article-text {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .article-text :global(p) {
    margin-bottom: 0.8em;
    text-indent: 1.5em;
  }

  .article-text :global(.content-heading) {
    font-weight: 700;
    text-indent: 0;
    margin-top: 1.2em;
    margin-bottom: 0.4em;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-primary);
  }

  .article-text :global(.content-image) {
    margin: var(--space-md) 0;
    text-align: center;
  }

  .article-text :global(.content-image img) {
    max-width: 100%;
    height: auto;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .article-text :global(.content-image figcaption) {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
    font-style: italic;
  }

  .article-text :global(.table-wrapper) {
    overflow-x: auto;
    margin: var(--space-md) 0;
    max-width: 100%;
  }

  .article-text :global(table) {
    border-collapse: collapse;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    line-height: 1.4;
    margin-left: auto;
    margin-right: auto;
  }

  .article-text :global(th),
  .article-text :global(td) {
    border: 1px solid var(--color-border);
    padding: 4px 8px;
    text-align: center;
  }

  .article-text :global(th) {
    background: var(--color-bg-secondary);
    font-weight: 600;
  }

  .article-text :global(td:first-child) {
    text-align: left;
  }
</style>
