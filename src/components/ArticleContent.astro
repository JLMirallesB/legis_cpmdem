---
import type { Lang, StructureNode } from '../lib/types';
import { t } from '../i18n/utils';

interface Props {
  node: StructureNode;
  lang: Lang;
}

const { node, lang } = Astro.props;
const hasVersions = node.versions && node.versions.length > 1;
const nodeId = node.id;

/** Convert a markdown table block into HTML <table> */
function mdTableToHtml(block: string): string {
  const lines = block.split('\n').filter(l => l.trim().startsWith('|'));
  if (lines.length < 2) return `<p>${block}</p>`;

  const parseRow = (line: string) =>
    line.split('|').slice(1, -1).map(c => c.trim());

  const headerCells = parseRow(lines[0]);
  // lines[1] is the separator (|---|---|...)
  const bodyRows = lines.slice(2);

  let html = '<div class="table-wrapper"><table>';
  html += '<thead><tr>' + headerCells.map(c => `<th>${c}</th>`).join('') + '</tr></thead>';
  html += '<tbody>';
  for (const row of bodyRows) {
    const cells = parseRow(row);
    html += '<tr>' + cells.map(c => {
      const bold = c.startsWith('**') && c.endsWith('**') && c.length > 4;
      const text = bold ? c.slice(2, -2) : c;
      return bold ? `<td><strong>${text}</strong></td>` : `<td>${text}</td>`;
    }).join('') + '</tr>';
  }
  html += '</tbody></table></div>';
  return html;
}

/** Render inline markdown: **bold** */
function renderInline(text: string): string {
  return text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
}

/** Render a content block: table, section heading, image, or paragraph */
function renderBlock(block: string): string {
  if (block.trimStart().startsWith('|') && block.includes('|---')) {
    return mdTableToHtml(block);
  }
  // Markdown image: ![alt](url)
  const imgMatch = block.match(/^!\[([^\]]*)\]\(([^)]+)\)$/);
  if (imgMatch) {
    return `<figure class="content-image"><img src="${imgMatch[2]}" alt="${imgMatch[1]}" loading="lazy"><figcaption>${imgMatch[1]}</figcaption></figure>`;
  }
  // A block that is entirely bold = section sub-heading
  if (block.startsWith('**') && block.endsWith('**') && !block.slice(2, -2).includes('**')) {
    return `<p class="content-heading">${block.slice(2, -2)}</p>`;
  }
  // Preserve single line breaks as <br> within a paragraph
  return `<p>${renderInline(block.replace(/\n/g, '<br>'))}</p>`;
}

const contentHtml = (node.content ?? node.versions?.[0]?.content ?? '')
  .split('\n\n')
  .map(renderBlock)
  .join('');
---

<article class="article-block" id={nodeId}>
  <h3 class="article-title">{node.title}</h3>

  {hasVersions && (
    <div class="version-selector" data-article-id={nodeId}>
      <span class="version-indicator version-current" data-indicator-id={nodeId}></span>
      <label>
        <span class="version-label">{t('law.select_version', lang)}:</span>
        <select class="version-select">
          {node.versions!.map((v, i) => (
            <option value={v.versionId} selected={i === 0}>
              {i === 0
                ? t('law.version_current', lang)
                : t('law.version', lang, { date: new Date(v.effectiveDate).toLocaleDateString(lang === 'va' ? 'ca-ES' : 'es-ES') })
              }
              {v.modifiedBy ? ` (${v.modifiedBy.title})` : ` (${t('law.version_original', lang)})`}
            </option>
          ))}
        </select>
      </label>
    </div>
  )}

  <div class="article-text" data-article-id={nodeId} set:html={contentHtml} />

  {hasVersions && (
    <script define:vars={{ nodeId, versions: node.versions }}>
      function renderBlock(block) {
        if (block.trimStart().startsWith('|') && block.includes('|---')) {
          const lines = block.split('\n').filter(l => l.trim().startsWith('|'));
          if (lines.length < 2) return `<p>${block}</p>`;
          const parseRow = (line) => line.split('|').slice(1, -1).map(c => c.trim());
          const hdr = parseRow(lines[0]);
          let html = '<div class="table-wrapper"><table><thead><tr>' +
            hdr.map(c => `<th>${c}</th>`).join('') + '</tr></thead><tbody>';
          for (const row of lines.slice(2)) {
            const cells = parseRow(row);
            html += '<tr>' + cells.map(c => {
              const b = c.startsWith('**') && c.endsWith('**');
              const t = b ? c.slice(2,-2) : c;
              return b ? `<td><strong>${t}</strong></td>` : `<td>${t}</td>`;
            }).join('') + '</tr>';
          }
          return html + '</tbody></table></div>';
        }
        if (block.startsWith('**') && block.endsWith('**') && !block.slice(2,-2).includes('**')) {
          return `<p class="content-heading">${block.slice(2,-2)}</p>`;
        }
        return `<p>${block.replace(/\n/g, '<br>').replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')}</p>`;
      }

      const selector = document.querySelector(`.version-selector[data-article-id="${nodeId}"] select`);
      const textContainer = document.querySelector(`.article-text[data-article-id="${nodeId}"]`);
      const indicator = document.querySelector(`.version-indicator[data-indicator-id="${nodeId}"]`);

      if (selector && textContainer) {
        selector.addEventListener('change', (e) => {
          const selectedId = e.target.value;
          const selectedIdx = versions.findIndex((v) => v.versionId === selectedId);
          const version = versions[selectedIdx];
          if (version) {
            textContainer.innerHTML = version.content
              .split('\n\n')
              .map(renderBlock)
              .join('');
          }
          if (indicator) {
            indicator.classList.toggle('version-current', selectedIdx === 0);
            indicator.classList.toggle('version-old', selectedIdx !== 0);
          }
        });
      }
    </script>
  )}
</article>

<style>
  .article-block {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
    scroll-margin-top: calc(var(--header-height) + var(--space-md));
  }

  .article-block:last-child {
    border-bottom: none;
  }

  .article-title {
    font-size: 1.05rem;
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
    font-weight: 600;
  }

  .version-selector {
    margin-bottom: var(--space-sm);
    padding: var(--space-xs) var(--space-sm);
    background: #fffbeb;
    border: 1px solid #fef3c7;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .version-indicator {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .version-current {
    background: #38a169;
    box-shadow: 0 0 0 2px rgba(56, 161, 105, 0.3);
  }

  .version-old {
    background: #d69e2e;
    box-shadow: 0 0 0 2px rgba(214, 158, 46, 0.3);
  }

  .version-label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-right: var(--space-xs);
  }

  .version-select {
    font-size: 0.8rem;
    padding: 2px 4px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    max-width: 100%;
  }

  .article-text {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .article-text :global(p) {
    margin-bottom: 0.8em;
    text-indent: 1.5em;
  }

  .article-text :global(.content-heading) {
    font-weight: 700;
    text-indent: 0;
    margin-top: 1.2em;
    margin-bottom: 0.4em;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-primary);
  }

  .article-text :global(.content-image) {
    margin: var(--space-md) 0;
    text-align: center;
  }

  .article-text :global(.content-image img) {
    max-width: 100%;
    height: auto;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .article-text :global(.content-image figcaption) {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-top: var(--space-xs);
    font-style: italic;
  }

  .article-text :global(.table-wrapper) {
    overflow-x: auto;
    margin: var(--space-md) 0;
    max-width: 100%;
  }

  .article-text :global(table) {
    border-collapse: collapse;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    line-height: 1.4;
    margin-left: auto;
    margin-right: auto;
  }

  .article-text :global(th),
  .article-text :global(td) {
    border: 1px solid var(--color-border);
    padding: 4px 8px;
    text-align: center;
  }

  .article-text :global(th) {
    background: var(--color-bg-secondary);
    font-weight: 600;
  }

  .article-text :global(td:first-child) {
    text-align: left;
  }
</style>
