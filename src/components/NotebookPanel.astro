---
import type { Lang } from '../lib/types';
import { t } from '../i18n/utils';
import { VERSION } from '../lib/version';

interface Props {
  lang: Lang;
  lawTitle: string;
  lawShort: string;
  lawSlug: string;
  apaRef: string;
  apaParen: string;
}

const { lang, lawTitle, lawShort, lawSlug, apaRef, apaParen } = Astro.props;
---

<!-- Floating trigger button -->
<button id="notebook-trigger" class="notebook-trigger" type="button" aria-label={t('notebook.title', lang)}>
  &#128221;
  <span id="notebook-badge" class="notebook-badge" hidden>0</span>
</button>

<!-- Selection tooltip -->
<div id="notebook-tooltip" class="notebook-tooltip">
  <span id="notebook-tooltip-ref" class="tooltip-ref"></span>
  <button id="notebook-save-btn" class="tooltip-save-btn" type="button">
    + {t('notebook.save', lang)}
  </button>
  <button id="notebook-cite-btn" class="tooltip-cite-btn" type="button">
    &#128220; {t('cite.copy_citation', lang)}
  </button>
</div>

<!-- Panel drawer -->
<div id="notebook-panel" class="notebook-panel" aria-label={t('notebook.title', lang)}>
  <div class="panel-header">
    <span class="panel-title">&#128221; {t('notebook.title', lang)}</span>
    <button id="notebook-close" class="panel-close" type="button" aria-label="Cerrar">&times;</button>
  </div>

  <div id="notebook-list" class="panel-list"></div>

  <div id="notebook-empty" class="panel-empty">
    <p>{t('notebook.empty', lang)}</p>
    <p class="panel-empty-hint">{t('notebook.empty_hint', lang)}</p>
  </div>

  <div class="panel-footer">
    <button id="notebook-copy-all" class="panel-btn panel-btn-primary" type="button">
      &#128203; {t('notebook.copy_all', lang)}
    </button>
    <button id="notebook-print" class="panel-btn" type="button">
      &#128438; {t('notebook.print', lang)}
    </button>
    <button id="notebook-clear" class="panel-btn panel-btn-danger" type="button">
      &#128465; {t('notebook.clear', lang)}
    </button>
  </div>
</div>


<script define:vars={{
  lang,
  lawTitle,
  lawShort,
  lawSlug,
  saveLabel: t('notebook.save', lang),
  savedLabel: t('notebook.saved', lang),
  copiedLabel: t('notebook.copied', lang),
  clearConfirm: t('notebook.clear_confirm', lang),
  moveUpLabel: t('notebook.move_up', lang),
  moveDownLabel: t('notebook.move_down', lang),
  deleteLabel: t('notebook.delete', lang),
  fromLabel: t('notebook.from', lang),
  generatedWith: lang === 'va'
    ? 'Generat amb Legis CPMDEM · https://JLMirallesB.github.io/legis_cpmdem/'
    : 'Generado con Legis CPMDEM · https://JLMirallesB.github.io/legis_cpmdem/',
  printTitle: lang === 'va'
    ? 'Quadern de fragments'
    : 'Cuaderno de fragmentos',
  printDisclaimer: lang === 'va'
    ? t('footer.personal_project', lang)
    : t('footer.personal_project', lang),
  printDisclaimerLong: lang === 'va'
    ? t('footer.disclaimer', lang)
    : t('footer.disclaimer', lang),
  siteUrl: 'https://JLMirallesB.github.io/legis_cpmdem/',
  appVersion: VERSION,
  apaRef,
  apaParen,
}}>
  const STORAGE_KEY = 'legis_notebook';

  // ── Helpers ────────────────────────────────────────────────
  function loadFragments() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); }
    catch { return []; }
  }

  function saveFragments(fragments) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(fragments));
  }

  function generateId() {
    return Date.now().toString(36) + Math.random().toString(36).slice(2, 7);
  }

  function formatArticleRef(nodeId) {
    if (!nodeId) return '';
    if (nodeId.startsWith('art-')) return `art. ${nodeId.slice(4)}`;
    if (nodeId.startsWith('da-')) return `disp. adic. ${nodeId.slice(3)}ª`;
    if (nodeId.startsWith('dt-')) return `disp. trans. ${nodeId.slice(3)}ª`;
    if (nodeId.startsWith('dd-')) return `disp. derog. ${nodeId.slice(3)}`;
    if (nodeId.startsWith('df-')) return `disp. final ${nodeId.slice(3)}ª`;
    if (nodeId.startsWith('anexo-')) return `anexo ${nodeId.slice(6).toUpperCase()}`;
    if (nodeId === 'preambulo') return 'preámbulo';
    return nodeId;
  }

  function buildParenthetical(articleId) {
    // apaParen is like "(Decreto 158/2007, 2007)" — inject article ref before closing paren
    if (!articleId) return apaParen;
    const ref = formatArticleRef(articleId);
    if (!ref) return apaParen;
    return apaParen.slice(0, -1) + `, ${ref})`;
  }

  function showToast(msg) {
    const toast = document.getElementById('sidebar-toast');
    if (!toast) return;
    toast.textContent = msg;
    toast.classList.add('visible');
    setTimeout(() => toast.classList.remove('visible'), 2000);
  }

  // ── Badge ──────────────────────────────────────────────────
  function updateBadge() {
    const badge = document.getElementById('notebook-badge');
    if (!badge) return;
    const count = loadFragments().length;
    badge.textContent = count;
    badge.hidden = count === 0;
  }

  // ── Render list ────────────────────────────────────────────
  function renderList() {
    const list = document.getElementById('notebook-list');
    const empty = document.getElementById('notebook-empty');
    if (!list || !empty) return;

    const fragments = loadFragments();
    list.innerHTML = '';

    if (fragments.length === 0) {
      list.style.display = 'none';
      empty.style.display = 'flex';
      return;
    }
    list.style.display = '';
    empty.style.display = 'none';

    fragments.forEach((frag, idx) => {
      const item = document.createElement('div');
      item.className = 'fragment-item';
      item.setAttribute('data-id', frag.id);

      // Header row: ref label + action buttons
      const header = document.createElement('div');
      header.className = 'fragment-header';

      const ref = document.createElement('span');
      ref.className = 'fragment-ref';
      ref.textContent = `${frag.lawShort.toUpperCase()} › ${frag.articleTitle}`;

      const actions = document.createElement('div');
      actions.className = 'fragment-actions';

      const up = document.createElement('button');
      up.type = 'button';
      up.className = 'frag-btn';
      up.textContent = '↑';
      up.title = moveUpLabel;
      up.disabled = idx === 0;
      up.addEventListener('click', () => moveFragment(frag.id, -1));

      const down = document.createElement('button');
      down.type = 'button';
      down.className = 'frag-btn';
      down.textContent = '↓';
      down.title = moveDownLabel;
      down.disabled = idx === fragments.length - 1;
      down.addEventListener('click', () => moveFragment(frag.id, 1));

      const del = document.createElement('button');
      del.type = 'button';
      del.className = 'frag-btn frag-btn-delete';
      del.textContent = '✕';
      del.title = deleteLabel;
      del.addEventListener('click', () => deleteFragment(frag.id));

      actions.append(up, down, del);
      header.append(ref, actions);

      if (frag.versionLabel) {
        const ver = document.createElement('div');
        ver.className = 'fragment-version';
        ver.textContent = frag.versionLabel;
        item.append(header, ver);
      } else {
        item.append(header);
      }

      const text = document.createElement('div');
      text.className = 'fragment-text';
      text.textContent = frag.text.length > 200 ? frag.text.slice(0, 200) + '…' : frag.text;

      item.append(text);
      list.appendChild(item);
    });
  }

  // ── Fragment operations ────────────────────────────────────
  function moveFragment(id, dir) {
    const fragments = loadFragments();
    const idx = fragments.findIndex(f => f.id === id);
    if (idx < 0) return;
    const newIdx = idx + dir;
    if (newIdx < 0 || newIdx >= fragments.length) return;
    [fragments[idx], fragments[newIdx]] = [fragments[newIdx], fragments[idx]];
    saveFragments(fragments);
    renderList();
  }

  function deleteFragment(id) {
    const fragments = loadFragments().filter(f => f.id !== id);
    saveFragments(fragments);
    updateBadge();
    renderList();
  }

  function getVersionLabel(articleId) {
    if (!articleId) return null;
    const selector = document.querySelector(`.version-selector[data-article-id="${articleId}"] select`);
    if (!selector) return null;
    const opt = selector.options[selector.selectedIndex];
    return opt ? opt.textContent.trim() : null;
  }

  function getFragmentHtml(articleEl) {
    if (!articleEl) return null;
    const textEl = articleEl.querySelector('.article-text');
    if (!textEl) return null;
    return textEl.innerHTML;
  }

  function addFragment(text, articleEl, selectedHtml = null) {
    const articleId = articleEl?.id || '';
    const titleEl = articleEl?.querySelector('h3');
    const articleTitle = titleEl ? titleEl.textContent.trim() : articleId;
    const url = window.location.href.split('#')[0] + (articleId ? '#' + articleId : '');
    const versionLabel = getVersionLabel(articleId);
    const html = selectedHtml !== null ? selectedHtml : getFragmentHtml(articleEl);

    const fragment = {
      id: generateId(),
      text: text.trim(),
      html,
      articleId,
      articleTitle,
      lawSlug,
      lawShort,
      lawTitle,
      url,
      versionLabel,
      apaParenthetical: buildParenthetical(articleId),
      apaReference: apaRef,
      savedAt: new Date().toISOString(),
    };

    const fragments = loadFragments();
    fragments.push(fragment);
    saveFragments(fragments);
    updateBadge();
    return fragment;
  }

  // ── Selection tooltip ─────────────────────────────────────
  const tooltip = document.getElementById('notebook-tooltip');
  const tooltipRef = document.getElementById('notebook-tooltip-ref');
  const saveBtn = document.getElementById('notebook-save-btn');
  let pendingSelection = null;

  function getArticleEl(node) {
    let el = node instanceof Element ? node : node.parentElement;
    while (el && !el.classList.contains('article-block')) {
      el = el.parentElement;
    }
    return el;
  }

  document.addEventListener('mouseup', (e) => {
    // Don't trigger inside the notebook panel itself
    if (tooltip?.contains(e.target) || document.getElementById('notebook-panel')?.contains(e.target)) return;

    setTimeout(() => {
      const sel = window.getSelection();
      const selText = sel?.toString().trim();
      if (!selText || selText.length < 5) {
        if (tooltip) tooltip.hidden = true;
        pendingSelection = null;
        return;
      }

      // Must be inside .law-content
      const anchor = sel.anchorNode;
      const lawContent = document.querySelector('.law-content');
      if (!lawContent || !lawContent.contains(anchor)) {
        if (tooltip) tooltip.hidden = true;
        pendingSelection = null;
        return;
      }

      const articleEl = getArticleEl(anchor);

      // Capture selected HTML before the range is lost
      const range = sel.getRangeAt(0);
      const container = document.createElement('div');
      container.appendChild(range.cloneContents());
      const selectedHtml = container.innerHTML;

      pendingSelection = { text: selText, articleEl, selectedHtml };

      if (tooltipRef && articleEl) {
        const titleEl = articleEl.querySelector('h3');
        tooltipRef.textContent = titleEl ? titleEl.textContent.trim() : '';
      }

      // Position tooltip near end of selection
      const rect = range.getBoundingClientRect();
      if (tooltip) {
        tooltip.style.display = 'flex';
        tooltip.style.top = (window.scrollY + rect.bottom + 6) + 'px';
        tooltip.style.left = Math.min(rect.left, window.innerWidth - 240) + 'px';
      }
    }, 10);
  });

  document.addEventListener('mousedown', (e) => {
    if (tooltip && !tooltip.contains(e.target)) {
      tooltip.style.display = 'none';
    }
  });

  function withEllipsis(selectedText, articleEl) {
    const articleTextEl = articleEl?.querySelector('.article-text');
    const fullText = articleTextEl?.innerText?.trim() || '';
    if (!fullText) return selectedText.trim();

    const norm = (s) => s.replace(/\s+/g, ' ').trim();
    const normFull = norm(fullText);
    const normSel = norm(selectedText);
    const idx = normFull.indexOf(normSel.slice(0, 80));
    if (idx < 0) return selectedText.trim();

    const before = normFull.slice(0, idx).trim();
    const after = normFull.slice(idx + normSel.length).trim();
    let result = selectedText.trim();
    if (before.length > 10) result = '[...] ' + result;
    if (after.length > 10) result = result + ' [...]';
    return result;
  }

  saveBtn?.addEventListener('click', () => {
    if (!pendingSelection) return;
    const text = withEllipsis(pendingSelection.text, pendingSelection.articleEl);
    addFragment(text, pendingSelection.articleEl, pendingSelection.selectedHtml);
    tooltip.style.display = 'none';
    pendingSelection = null;
    window.getSelection()?.removeAllRanges();
    showToast(savedLabel);
    renderList();
  });

  // ── Cite selection ────────────────────────────────────────
  const citeSelBtn = document.getElementById('notebook-cite-btn');
  citeSelBtn?.addEventListener('click', () => {
    if (!pendingSelection) return;
    const articleId = pendingSelection.articleEl?.id || '';
    // Dispatch to LawReaderLayout which has the citation data
    document.dispatchEvent(new CustomEvent('cite:selection', {
      detail: { selectedText: pendingSelection.text.trim(), articleId }
    }));
    tooltip.style.display = 'none';
    pendingSelection = null;
    window.getSelection()?.removeAllRanges();
  });

  // ── Listener para guardar artículo completo desde el popover ─
  document.addEventListener('notebook:save-request', (e) => {
    const { text, articleId, articleTitle } = e.detail;
    const url = window.location.href.split('#')[0] + (articleId ? '#' + articleId : '');
    const versionLabel = getVersionLabel(articleId);
    const articleEl = articleId ? document.getElementById(articleId) : null;
    const html = getFragmentHtml(articleEl);
    const fragment = {
      id: generateId(),
      text,
      html,
      articleId,
      articleTitle,
      lawSlug,
      lawShort,
      lawTitle,
      url,
      versionLabel,
      apaParenthetical: buildParenthetical(articleId),
      apaReference: apaRef,
      savedAt: new Date().toISOString(),
    };
    const fragments = loadFragments();
    fragments.push(fragment);
    saveFragments(fragments);
    updateBadge();
    if (document.getElementById('notebook-panel')?.classList.contains('is-open')) {
      renderList();
    }
  });

  // ── Panel open/close ───────────────────────────────────────
  const panel = document.getElementById('notebook-panel');
  document.getElementById('notebook-trigger')?.addEventListener('click', () => {
    if (panel) {
      const isOpen = panel.classList.toggle('is-open');
      if (isOpen) renderList();
    }
  });
  document.getElementById('notebook-close')?.addEventListener('click', () => {
    panel?.classList.remove('is-open');
  });

  // ── Copy all ───────────────────────────────────────────────
  document.getElementById('notebook-copy-all')?.addEventListener('click', () => {
    const fragments = loadFragments();
    if (fragments.length === 0) return;

    const lines = fragments.map(f => {
      const ver = f.versionLabel ? ` [${f.versionLabel}]` : '';
      return `${f.lawShort} — ${f.articleTitle}${ver}\n${f.url}\n\n"${f.text}"`;
    });
    const text = lines.join('\n\n---\n\n') + '\n\n---\n' + generatedWith;

    navigator.clipboard.writeText(text).then(() => showToast(copiedLabel)).catch(() => {
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.cssText = 'position:fixed;opacity:0';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      showToast(copiedLabel);
    });
  });

  // ── Print ──────────────────────────────────────────────────
  function openPrintPreview(opts) {
    const { userName, showFooter, showLinks } = opts;
    const fragments = loadFragments();
    if (fragments.length === 0) return;

    const locale = lang === 'va' ? 'ca-ES' : 'es-ES';
    const now = new Date().toLocaleDateString(locale, { year: 'numeric', month: 'long', day: 'numeric' });

    // Build body: group consecutive fragments from the same law
    let bodyHtml = '';
    let prevLawSlug = null;

    fragments.forEach((f) => {
      const isNewLaw = f.lawSlug !== prevLawSlug;
      if (isNewLaw) {
        if (prevLawSlug !== null) bodyHtml += '</div>';
        bodyHtml += `<div class="law-group">
          <h2 class="law-heading">${f.lawShort.toUpperCase()}</h2>
          <p class="law-full-title">${f.lawTitle}</p>`;
        prevLawSlug = f.lawSlug;
      }
      const versionHtml = f.versionLabel ? `<span class="fragment-version">${f.versionLabel}</span>` : '';
      const hasBefore = f.text.startsWith('[...] ');
      const hasAfter = f.text.endsWith(' [...]');
      const contentHtml = f.html
        ? `${hasBefore ? '<p class="fragment-ellipsis">[…]</p>' : ''}<div class="fragment-content">${f.html}</div>${hasAfter ? '<p class="fragment-ellipsis">[…]</p>' : ''}`
        : `<blockquote class="fragment-text">${f.text.replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/\n/g, '<br>')}</blockquote>`;
      const parenHtml = f.apaParenthetical ? `<p class="fragment-cite">${f.apaParenthetical}</p>` : '';
      bodyHtml += `
        <div class="fragment">
          <h3 class="fragment-ref">${f.articleTitle}${versionHtml}</h3>
          ${contentHtml}
          ${parenHtml}
          ${showLinks ? `<p class="fragment-url">${f.url}</p>` : ''}
        </div>`;
    });
    if (prevLawSlug !== null) bodyHtml += '</div>';

    // Build unique references section
    const refsMap = new Map();
    fragments.forEach(f => {
      if (f.apaReference && !refsMap.has(f.lawSlug)) {
        refsMap.set(f.lawSlug, f.apaReference);
      }
    });
    let refsHtml = '';
    if (refsMap.size > 0) {
      const refsTitle = lang === 'va' ? 'Referències legals' : 'Referencias legales';
      const refEntries = Array.from(refsMap.values())
        .map(r => `<p class="ref-entry">${r.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</p>`)
        .join('');
      refsHtml = `<section class="references-section">
        <h2 class="references-title">${refsTitle}</h2>
        ${refEntries}
      </section>`;
    }

    const printBtnLabel = lang === 'va' ? 'Imprimir' : 'Imprimir';
    const currentYear = new Date().getFullYear();
    const contactLabel = lang === 'va' ? 'Contacte' : 'Contacto';
    const reportLabel = lang === 'va' ? 'Notificar un error (GitHub)' : 'Notificar un error (GitHub)';
    const orxataLabel = lang === 'va' ? "Invita'm a una orxata" : 'Invítame a una orxata';

    const userNameHtml = userName
      ? `<div class="user-name">${userName.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</div>`
      : '';

    const footerHtml = showFooter ? `
  <footer class="print-footer">
    <div class="footer-disclaimer">${printDisclaimer}<br>${printDisclaimerLong}</div>
    <div class="footer-contact">
      <strong>${contactLabel}</strong><br>
      jl.mirallesbono@edu.gva.es<br>
      <a href="https://github.com/JLMirallesB/legis_cpmdem/issues">${reportLabel}</a><br>
      <a href="https://ko-fi.com/miralles">${orxataLabel} &#9749;</a>
    </div>
    <div class="footer-copyright">&copy; ${currentYear} Jos&eacute; Luis Miralles Bono &middot; Legis CPMDEM v${appVersion}</div>
  </footer>` : '';

    const html = `<!DOCTYPE html>
<html lang="${lang}">
<head>
  <meta charset="utf-8">
  <title>${printTitle} – Legis CPMDEM</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: Georgia, 'Times New Roman', serif; font-size: 9pt; color: #000; padding: 1cm 1.5cm; line-height: 1.45; }

    /* Print toolbar (hidden when printing) */
    .print-toolbar { position: fixed; top: 0; left: 0; right: 0; background: #333; color: #fff; padding: 8px 16px; display: flex; align-items: center; justify-content: space-between; z-index: 100; font-family: Arial, sans-serif; font-size: 10pt; }
    .print-toolbar button { background: #fff; color: #333; border: none; padding: 6px 18px; border-radius: 4px; font-size: 10pt; font-weight: bold; cursor: pointer; }
    .print-toolbar button:hover { background: #e2e8f0; }
    .toolbar-spacer { height: 40px; }

    /* Header */
    .print-header { display: flex; justify-content: space-between; align-items: flex-end; border-bottom: 1.5pt solid #000; padding-bottom: 6pt; margin-bottom: 12pt; }
    .header-left .site-name { font-family: Arial, sans-serif; font-size: 12pt; font-weight: bold; color: #000; }
    .header-left .site-url { font-family: monospace; font-size: 7pt; color: #000; margin-top: 1pt; }
    .header-right { text-align: right; font-family: Arial, sans-serif; font-size: 7.5pt; color: #000; }
    .header-right .doc-title { font-weight: bold; font-size: 9pt; }
    .user-name { font-family: Arial, sans-serif; font-size: 8pt; font-weight: bold; margin-top: 6pt; margin-bottom: 6pt; }

    /* Law groups */
    .law-group { margin-bottom: 10pt; }
    .law-heading { font-family: Arial, sans-serif; font-size: 9.5pt; font-weight: bold; color: #000; border-left: 3pt solid #000; padding-left: 6pt; margin-bottom: 1pt; }
    .law-full-title { font-family: Arial, sans-serif; font-size: 7pt; color: #000; margin-bottom: 6pt; padding-left: 9pt; }

    /* Fragments */
    .fragment { margin-bottom: 8pt; padding-left: 9pt; page-break-inside: avoid; }
    .fragment-ref { font-family: Arial, sans-serif; font-size: 8pt; font-weight: bold; color: #000; margin-bottom: 2pt; }
    .fragment-version { font-family: Arial, sans-serif; font-size: 7pt; font-style: italic; font-weight: normal; }
    .fragment-text { font-size: 8.5pt; font-style: italic; border-left: 1.5pt solid #000; padding: 2pt 6pt; margin: 2pt 0; color: #000; }
    .fragment-ellipsis { font-size: 8pt; color: #666; font-style: italic; margin: 1pt 0; padding-left: 6pt; }
    .fragment-content { font-size: 8.5pt; border-left: 1.5pt solid #000; padding: 2pt 6pt; margin: 2pt 0; color: #000; }
    .fragment-content p { margin-bottom: 4pt; }
    .fragment-content .content-heading { font-weight: bold; margin: 6pt 0 2pt; }
    .fragment-content table { border-collapse: collapse; width: 100%; margin: 4pt 0; font-size: 7.5pt; }
    .fragment-content th, .fragment-content td { border: 0.5pt solid #000; padding: 2pt 4pt; text-align: left; }
    .fragment-content th { font-weight: bold; background: #f0f0f0; }
    .fragment-cite { font-family: Arial, sans-serif; font-size: 7.5pt; color: #000; margin-top: 2pt; text-align: right; font-style: italic; }
    .fragment-url { font-family: monospace; font-size: 6pt; color: #000; margin-top: 2pt; }

    /* References */
    .references-section { margin-top: 16pt; padding-top: 8pt; border-top: 1.5pt solid #000; }
    .references-title { font-family: Arial, sans-serif; font-size: 10pt; font-weight: bold; color: #000; margin-bottom: 6pt; }
    .ref-entry { font-size: 8pt; margin-bottom: 4pt; padding-left: 18pt; text-indent: -18pt; color: #000; }

    /* Footer */
    .print-footer { margin-top: 16pt; padding-top: 6pt; border-top: 1pt solid #000; font-family: Arial, sans-serif; font-size: 7pt; color: #000; }
    .footer-disclaimer { margin-top: 4pt; font-size: 6.5pt; }
    .footer-contact { margin-top: 6pt; font-size: 7pt; }
    .footer-contact strong { font-size: 7.5pt; }
    .footer-contact a { color: #000; }
    .footer-copyright { margin-top: 6pt; font-size: 7pt; font-weight: bold; }

    @media print {
      .print-toolbar, .toolbar-spacer { display: none; }
      body { padding: 0; }
      @page { margin: 1cm 1.2cm; }
    }
  </style>
</head>
<body>
  <div class="print-toolbar">
    <span>${printTitle} — ${fragments.length} fragment${fragments.length !== 1 ? 's' : ''}</span>
    <button onclick="window.print()">${printBtnLabel}</button>
  </div>
  <div class="toolbar-spacer"></div>

  <header class="print-header">
    <div class="header-left">
      <div class="site-name">Legis CPMDEM</div>
      <div class="site-url">${siteUrl}</div>
    </div>
    <div class="header-right">
      <div class="doc-title">${printTitle}</div>
      <div>${now}</div>
      <div>${fragments.length} fragment${fragments.length !== 1 ? 's' : ''}</div>
    </div>
  </header>

  ${userNameHtml}

  <main>${bodyHtml}</main>

  ${refsHtml}

  ${footerHtml}
</body>
</html>`;

    const pw = window.open('', '_blank', 'width=800,height=600');
    if (!pw) { alert('Permite las ventanas emergentes para imprimir.'); return; }
    pw.document.write(html);
    pw.document.close();
  }

  // ── Print options modal ───────────────────────────────────
  document.getElementById('notebook-print')?.addEventListener('click', () => {
    const fragments = loadFragments();
    if (fragments.length === 0) return;

    // Remove existing modal if any
    document.getElementById('print-options-modal')?.remove();

    const nameLabel = lang === 'va' ? 'Nom (opcional):' : 'Nombre (opcional):';
    const footerLabel = lang === 'va' ? 'Incloure peu de pàgina' : 'Incluir pie de página';
    const linksLabel = lang === 'va' ? 'Incloure enllaços dels articles' : 'Incluir enlaces de los artículos';
    const previewLabel = lang === 'va' ? 'Previsualitzar' : 'Previsualizar';
    const cancelLabel = lang === 'va' ? 'Cancel·lar' : 'Cancelar';

    const modal = document.createElement('div');
    modal.id = 'print-options-modal';
    modal.className = 'print-modal-overlay';
    modal.innerHTML = `
      <div class="print-modal">
        <div class="print-modal-title">${printTitle}</div>
        <label class="print-modal-label">
          ${nameLabel}
          <input type="text" id="print-opt-name" class="print-modal-input" placeholder="${lang === 'va' ? 'Ex: Maria García' : 'Ej: María García'}">
        </label>
        <label class="print-modal-check">
          <input type="checkbox" id="print-opt-footer" checked>
          ${footerLabel}
        </label>
        <label class="print-modal-check">
          <input type="checkbox" id="print-opt-links" checked>
          ${linksLabel}
        </label>
        <div class="print-modal-actions">
          <button type="button" id="print-opt-cancel" class="print-modal-btn">${cancelLabel}</button>
          <button type="button" id="print-opt-go" class="print-modal-btn print-modal-btn-primary">${previewLabel}</button>
        </div>
      </div>`;

    document.body.appendChild(modal);

    document.getElementById('print-opt-cancel').addEventListener('click', () => modal.remove());
    modal.addEventListener('click', (e) => { if (e.target === modal) modal.remove(); });

    document.getElementById('print-opt-go').addEventListener('click', () => {
      const userName = document.getElementById('print-opt-name').value.trim();
      const showFooter = document.getElementById('print-opt-footer').checked;
      const showLinks = document.getElementById('print-opt-links').checked;
      modal.remove();
      openPrintPreview({ userName, showFooter, showLinks });
    });
  });

  // ── Clear ──────────────────────────────────────────────────
  document.getElementById('notebook-clear')?.addEventListener('click', () => {
    if (!confirm(clearConfirm)) return;
    saveFragments([]);
    updateBadge();
    renderList();
  });

  // ── Init ───────────────────────────────────────────────────
  updateBadge();
</script>

