---
import type { Lang, Law } from '../lib/types';
import BaseLayout from './BaseLayout.astro';
import LawSidebar from '../components/LawSidebar.astro';
import VigencyBadge from '../components/VigencyBadge.astro';
import DownloadButtons from '../components/DownloadButtons.astro';
import FormModelButtons from '../components/FormModelButtons.astro';
import LegalAnalysis from '../components/LegalAnalysis.astro';
import LawTags from '../components/LawTags.astro';
import NotebookPanel from '../components/NotebookPanel.astro';
import { t } from '../i18n/utils';
import { buildCitationData, apaReference, apaParenthetical } from '../lib/apa-citation';

interface Props {
  law: Law;
  lang: Lang;
}

const { law, lang } = Astro.props;
const base = import.meta.env.BASE_URL;
const citationData = buildCitationData(law);
const fullReference = apaReference(citationData);
const parenthetical = apaParenthetical(citationData);
const dateFormatted = new Date(law.date).toLocaleDateString(lang === 'va' ? 'ca-ES' : 'es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout lang={lang} title={law.titleShort}>
  <div class="container law-reader">
    <div class="law-header">
      <div class="law-breadcrumb">
        <a href={`${base}${lang}/`}>{t('nav.home', lang)}</a>
        <span>&rsaquo;</span>
        <span>{law.titleShort}</span>
      </div>
      <h1>{law.title}</h1>
      <div class="law-meta">
        <VigencyBadge status={law.vigpiracy.status} lang={lang} />
        <LawTags scope={law.scope} territory={law.territory} temporality={law.temporality} docType={law.docType} lang={lang} />
        <span class="law-date">{dateFormatted}</span>
        <span class="law-source">{law.publishedIn.source} n&uacute;m. {law.publishedIn.number}</span>
        {law.publishedIn.url && (
          <a href={law.publishedIn.url} target="_blank" rel="noopener" class="btn btn-source">
            {t('download.view_source', lang, { source: law.publishedIn.source })} &nearr;
          </a>
        )}
        {law.publishedIn.pdfUrl && (
          <a href={law.publishedIn.pdfUrl} target="_blank" rel="noopener" class="btn btn-pdf">
            {t('download.view_pdf', lang)} &darr;
          </a>
        )}
      </div>
      <DownloadButtons law={law} lang={lang} />
      {law.formModels && law.formModels.length > 0 && (
        <FormModelButtons models={law.formModels} lang={lang} />
      )}
      <div class="cite-apa-wrap">
        <button class="btn btn-cite" id="cite-apa-btn" type="button">
          &#128220; {t('cite.button', lang)}
        </button>
        <div id="cite-apa-popover" class="cite-popover" hidden>
          <button class="cite-option" id="cite-parenthetical" type="button">
            {t('cite.parenthetical', lang)}
          </button>
          <button class="cite-option" id="cite-reference" type="button">
            {t('cite.reference', lang)}
          </button>
        </div>
      </div>

      <div class="share-buttons" role="group" aria-label={lang === 'va' ? 'Compartir' : 'Compartir'}>
        <button class="btn btn-share" id="share-copy-link" type="button">
          &#128279; {t('share.copy_link', lang)}
        </button>
        <a
          class="btn btn-share"
          id="share-email"
          href="#"
          rel="noopener"
        >&#9993; {t('share.email', lang)}</a>
        <a
          class="btn btn-share"
          id="share-whatsapp"
          href="#"
          target="_blank"
          rel="noopener noreferrer"
        >&#128172; {t('share.whatsapp', lang)}</a>
        <button class="btn btn-share" id="share-embed-btn" type="button">
          &lt;/&gt; {t('share.embed', lang)}
        </button>
        <div id="share-embed-popover" class="embed-popover" hidden>
          <p class="embed-label">{t('share.embed_code', lang)}</p>
          <textarea id="share-embed-code" class="embed-textarea" readonly rows="3"></textarea>
          <div class="embed-actions">
            <button class="btn btn-share" id="share-embed-copy" type="button">{t('share.copy_link', lang)}</button>
            <button class="btn btn-share" id="share-embed-close" type="button">{t('share.embed_close', lang)}</button>
          </div>
        </div>
      </div>
    </div>

    {law.legalAnalysis && (
      <details class="analysis-collapsible">
        <summary>{t('analysis.title', lang)}</summary>
        <LegalAnalysis analysis={law.legalAnalysis} vigpiracy={law.vigpiracy} lang={lang} />
      </details>
    )}

    <div class="law-body">
      <LawSidebar structure={law.structure} lang={lang} promulgation={law.promulgation} sidebarLabel={`${law.type.replace(/_/g, ' ')} ${law.number}`} />
      <div class="law-content">
        <slot />
      </div>
    </div>
  </div>

  <NotebookPanel lang={lang} lawTitle={law.title} lawShort={`${law.type.replace(/_/g, ' ')} ${law.number}`} lawSlug={law.slug} apaRef={fullReference} apaParen={parenthetical} />
</BaseLayout>

<style>
  .law-reader {
    padding: var(--space-lg) 0 var(--space-2xl);
  }

  .law-breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .law-breadcrumb a {
    color: var(--color-text-muted);
  }

  .law-breadcrumb a:hover {
    color: var(--color-primary);
  }

  .law-header {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 2px solid var(--color-border);
  }

  .law-header h1 {
    font-size: 1.4rem;
    color: var(--color-primary);
    line-height: 1.4;
    margin-bottom: var(--space-md);
  }

  .law-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm) var(--space-md);
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .btn-source, .btn-pdf {
    font-size: 0.8rem;
  }

  .analysis-collapsible {
    margin-bottom: var(--space-xl);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-white);
  }

  .analysis-collapsible summary {
    padding: var(--space-sm) var(--space-md);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-primary-dark);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .analysis-collapsible summary::before {
    content: '\25B6';
    font-size: 0.7rem;
    transition: transform 0.2s;
  }

  .analysis-collapsible[open] summary::before {
    transform: rotate(90deg);
  }

  .analysis-collapsible summary::-webkit-details-marker {
    display: none;
  }

  .law-body {
    display: grid;
    grid-template-columns: var(--sidebar-width) 1fr;
    gap: var(--space-xl);
  }

  @media (max-width: 768px) {
    .law-body {
      grid-template-columns: 1fr;
    }

    .law-header h1 {
      font-size: 1.2rem;
    }
  }

  /* Share buttons */
  .share-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
    position: relative;
  }

  .btn-share {
    font-size: 0.8rem;
    padding: var(--space-xs) var(--space-sm);
    cursor: pointer;
    border: 1px solid #81c784;
    background: #f1f8f1;
    color: #2e7d32;
    border-radius: var(--radius-sm);
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    text-decoration: none;
  }

  .btn-share:hover {
    background: #c8e6c9;
    color: #1b5e20;
    border-color: #388e3c;
    text-decoration: none;
  }

  /* Embed popover */
  .embed-popover {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    background: var(--color-bg-white);
    border: 1px solid var(--color-border-dark);
    border-radius: var(--radius-md);
    padding: var(--space-md);
    box-shadow: var(--shadow-lg);
    z-index: 100;
    min-width: 380px;
    max-width: 95vw;
  }

  .embed-label {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xs);
    font-family: var(--font-sans);
  }

  .embed-textarea {
    width: 100%;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: var(--space-xs);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    resize: none;
    color: var(--color-text);
    background: var(--color-bg-secondary);
  }

  .embed-actions {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }

  /* APA Citation */
  .cite-apa-wrap {
    position: relative;
    display: inline-block;
    margin-top: var(--space-sm);
  }

  .btn-cite {
    background: #744210;
    color: #fff;
    border: 1px solid #744210;
    font-size: 0.82rem;
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-weight: 600;
    transition: background 0.15s;
  }

  .btn-cite:hover {
    background: #975a16;
  }

  .cite-popover {
    position: absolute;
    top: 100%;
    left: 0;
    margin-top: 4px;
    background: var(--color-bg-white);
    border: 1px solid var(--color-border-dark);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    z-index: 100;
    display: none;
    flex-direction: column;
    min-width: 200px;
  }

  .cite-popover:not([hidden]) {
    display: flex;
  }

  .cite-option {
    background: none;
    border: none;
    padding: var(--space-sm) var(--space-md);
    text-align: left;
    font-size: 0.85rem;
    cursor: pointer;
    color: var(--color-text);
    font-family: var(--font-sans);
    transition: background 0.1s;
  }

  .cite-option:hover {
    background: var(--color-bg-secondary);
  }

  .cite-option + .cite-option {
    border-top: 1px solid var(--color-border);
  }
</style>

<script define:vars={{
  lawTitle: law.title,
  lawShort: `${law.type.replace(/_/g, ' ')} ${law.number}`,
  copiedMsg: t('share.link_copied', lang),
  citeCopiedMsg: t('cite.copied', lang),
  citeParenthetical: parenthetical,
  citeReference: fullReference,
  embedCopiedMsg: t('share.embed_copied', lang),
  promoText: lang === 'va'
    ? '\n\n--\n📚 Compartit des de Legis CPM, lector de legislació de Conservatoris Professionals de Música i Dansa de la Comunitat Valenciana.\nhttps://JLMirallesB.github.io/legis_cpm/'
    : '\n\n--\n📚 Compartido desde Legis CPM, lector de legislación de Conservatorios Profesionales de Música y Danza de la Comunitat Valenciana.\nhttps://JLMirallesB.github.io/legis_cpm/',
}}>
  function getBaseUrl() {
    return window.location.origin + window.location.pathname;
  }

  function showToast(msg) {
    const toast = document.getElementById('sidebar-toast');
    if (!toast) return;
    toast.textContent = msg;
    toast.classList.add('visible');
    setTimeout(() => toast.classList.remove('visible'), 2000);
  }

  function copyText(text, msg) {
    navigator.clipboard.writeText(text).then(() => showToast(msg)).catch(() => {
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.cssText = 'position:fixed;opacity:0';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      showToast(msg);
    });
  }

  // Copy link
  document.getElementById('share-copy-link')?.addEventListener('click', () => {
    copyText(getBaseUrl(), copiedMsg);
  });

  // Email
  const emailLink = document.getElementById('share-email');
  if (emailLink) {
    emailLink.addEventListener('click', (e) => {
      e.preventDefault();
      const subject = encodeURIComponent(lawTitle);
      const body = encodeURIComponent(getBaseUrl() + promoText);
      window.location.href = `mailto:?subject=${subject}&body=${body}`;
    });
  }

  // WhatsApp
  const waLink = document.getElementById('share-whatsapp');
  if (waLink) {
    waLink.addEventListener('click', (e) => {
      e.preventDefault();
      const text = encodeURIComponent(lawShort + ' — ' + getBaseUrl() + promoText);
      window.open('https://wa.me/?text=' + text, '_blank', 'noopener,noreferrer');
    });
  }

  // Embed popover
  const embedBtn = document.getElementById('share-embed-btn');
  const embedPopover = document.getElementById('share-embed-popover');
  const embedCode = document.getElementById('share-embed-code');
  const embedCopy = document.getElementById('share-embed-copy');
  const embedClose = document.getElementById('share-embed-close');

  if (embedBtn && embedPopover && embedCode) {
    embedBtn.addEventListener('click', () => {
      const url = getBaseUrl();
      embedCode.value = `<iframe src="${url}" width="100%" height="600" style="border:1px solid #e2e8f0;border-radius:8px;" title="${lawShort}"></iframe>`;
      embedPopover.hidden = !embedPopover.hidden;
      if (!embedPopover.hidden) embedCode.select();
    });

    embedCopy?.addEventListener('click', () => {
      copyText(embedCode.value, embedCopiedMsg);
    });

    embedClose?.addEventListener('click', () => {
      embedPopover.hidden = true;
    });

    document.addEventListener('click', (e) => {
      if (!embedPopover.hidden && !embedPopover.contains(e.target) && e.target !== embedBtn) {
        embedPopover.hidden = true;
      }
    });
  }

  // APA Citation helpers
  function formatArticleRef(nodeId) {
    if (nodeId.startsWith('art-')) return 'art. ' + nodeId.slice(4);
    if (nodeId.startsWith('da-')) return 'disp. adic. ' + nodeId.slice(3) + 'ª';
    if (nodeId.startsWith('dt-')) return 'disp. trans. ' + nodeId.slice(3) + 'ª';
    if (nodeId.startsWith('dd-')) return 'disp. derog. ' + nodeId.slice(3);
    if (nodeId.startsWith('df-')) return 'disp. final ' + nodeId.slice(3) + 'ª';
    if (nodeId.startsWith('anexo-')) return 'anexo ' + nodeId.slice(6).toUpperCase();
    if (nodeId === 'preambulo') return 'preámbulo';
    return nodeId;
  }

  function apaParenthetical(articleId) {
    const base = citeParenthetical.slice(0, -1); // remove trailing ")"
    if (articleId) return base + ', ' + formatArticleRef(articleId) + ')';
    return citeParenthetical;
  }

  function apaReferenceForArticle(articleId) {
    if (articleId) return citeReference; // full reference is the same, article ref goes in parenthetical
    return citeReference;
  }

  // Listen for cite:request from ArticleContent popovers
  document.addEventListener('cite:request', (e) => {
    const { type, articleId } = e.detail;
    let text;
    if (type === 'cite-parenthetical') {
      text = apaParenthetical(articleId);
    } else {
      text = citeReference;
    }
    copyText(text, citeCopiedMsg);
  });

  // Listen for cite:selection from NotebookPanel tooltip
  document.addEventListener('cite:selection', (e) => {
    const { selectedText, articleId } = e.detail;
    const paren = apaParenthetical(articleId);
    const text = `"${selectedText}" ${paren}\n\n${citeReference}`;
    copyText(text, citeCopiedMsg);
  });

  // APA Citation popover (law-level)
  const citeBtn = document.getElementById('cite-apa-btn');
  const citePop = document.getElementById('cite-apa-popover');
  if (citeBtn && citePop) {
    citeBtn.addEventListener('click', () => {
      citePop.hidden = !citePop.hidden;
    });
    document.getElementById('cite-parenthetical')?.addEventListener('click', () => {
      copyText(citeParenthetical, citeCopiedMsg);
      citePop.hidden = true;
    });
    document.getElementById('cite-reference')?.addEventListener('click', () => {
      copyText(citeReference, citeCopiedMsg);
      citePop.hidden = true;
    });
    document.addEventListener('click', (e) => {
      if (!citePop.hidden && !citePop.contains(e.target) && e.target !== citeBtn) {
        citePop.hidden = true;
      }
    });
  }
</script>
